@{
    ViewData["Title"] = "Table Order History";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Table Order History</h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <di class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold">Paid / closed table orders</h3>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Only orders with status <strong>Done</strong> (bill paid / closed) appear here.
                    Use <a href="@Url.Action("OrderHistory", "Entry")">Order History</a> for all statuses.
                </p>
                <table id="tableOrderHistoryTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Order ID</th>
                            <th>Table</th>
                            <th>Total</th>
                            <th>Detail</th>
                            <th>Created At</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="tableOrderDetailModal" tabindex="-1" role="dialog" aria-labelledby="tableOrderDetailTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableOrderDetailTitle">Order detail</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="mb-2 text-muted small" id="tableOrderDetailMeta"></p>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th class="text-right">Qty</th>
                                <th class="text-right">Unit (MMK)</th>
                                <th class="text-right">Line (MMK)</th>
                            </tr>
                        </thead>
                        <tbody id="tableOrderDetailLines"></tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-right">Total</th>
                                <th class="text-right" id="tableOrderDetailTotal"></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        loadTableOrderHistory();
    });

    function loadTableOrderHistory() {
        $.ajax({
            url: '/api/admin/table_order_history',
            method: 'GET',
            dataType: 'json',
            cache: false
        }).done(function (res) {
            const orders = (res && (res.orders || res.Orders)) ? (res.orders || res.Orders) : [];
            let html = '';

            orders.forEach(function (o, idx) {
                const oid = o.order_id ?? o.orderId;
                const label = o.table_label ?? o.tableLabel ?? '-';
                const totalAmt = parseFloat(o.order_total ?? o.orderTotal ?? 0).toLocaleString();
                const created = o.created_at ?? o.createdAt;
                const dt = created ? new Date(created).toLocaleString() : '-';
                html += `<tr>
                    <td>${idx + 1}</td>
                    <td>${oid}</td>
                    <td>${label}</td>
                    <td>${totalAmt} MMK</td>
                    <td><button type="button" class="btn btn-sm btn-info" onclick="openTableOrderDetail(${oid})">Detail</button></td>
                    <td>${dt}</td>
                </tr>`;
            });

            if (!html) {
                html = '<tr><td colspan="6" class="text-center text-muted">No paid table orders yet.</td></tr>';
            }

            $('#tableOrderHistoryTable tbody').html(html);
        }).fail(function (xhr) {
            console.error('Table order history failed', xhr.status, xhr.responseText);
            $('#tableOrderHistoryTable tbody').html(
                '<tr><td colspan="6" class="text-center text-danger">Failed to load table order history (HTTP ' + xhr.status + ').</td></tr>');
            alert('Failed to load table order history');
        });
    }

    function openTableOrderDetail(orderId) {
        $('#tableOrderDetailLines').html('<tr><td colspan="4" class="text-center text-muted">Loading…</td></tr>');
        $('#tableOrderDetailMeta').text('');
        $('#tableOrderDetailTotal').text('');
        $('#tableOrderDetailModal').modal('show');

        $.ajax({
            url: '/api/admin/table_order_detail/' + orderId,
            method: 'GET',
            dataType: 'json',
            cache: false
        }).done(function (d) {
            const label = d.table_label ?? d.tableLabel ?? '-';
            const created = d.created_at ?? d.createdAt;
            const dt = created ? new Date(created).toLocaleString() : '-';
            $('#tableOrderDetailTitle').text('Order #' + (d.order_id ?? d.orderId ?? orderId));
            $('#tableOrderDetailMeta').text('Table: ' + label + ' · Created: ' + dt + ' · Status: ' + (d.status ?? ''));

            const items = d.items || d.Items || [];
            let rows = '';
            items.forEach(function (it) {
                const name = it.recipe_name ?? it.recipeName ?? '';
                const qty = it.qty ?? it.Qty ?? 0;
                const price = parseFloat(it.price ?? it.Price ?? 0).toLocaleString();
                const line = parseFloat(it.line_total ?? it.lineTotal ?? 0).toLocaleString();
                rows += `<tr>
                    <td>${name}</td>
                    <td class="text-right">${qty}</td>
                    <td class="text-right">${price}</td>
                    <td class="text-right">${line}</td>
                </tr>`;
            });
            if (!rows) {
                rows = '<tr><td colspan="4" class="text-center text-muted">No line items.</td></tr>';
            }
            $('#tableOrderDetailLines').html(rows);
            const tot = parseFloat(d.order_total ?? d.orderTotal ?? 0).toLocaleString();
            $('#tableOrderDetailTotal').text(tot);
        }).fail(function (xhr) {
            $('#tableOrderDetailLines').html(
                '<tr><td colspan="4" class="text-center text-danger">Could not load detail (HTTP ' + xhr.status + ').</td></tr>');
            if (xhr.status === 404) {
                $('#tableOrderDetailMeta').text('This order is not available or is not paid yet.');
            }
        });
    }
</script>
}
