@model FoodOutlet.Models.Staff
@{
    bool isEdit = Model != null && Model.id > 0;
    ViewData["Title"] = isEdit ? Model.name : "Registration";
}


<div class="content-header">
    <div class="container-fluid">
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12 col-sm-12 col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">
                            @(isEdit ? "Edit \"" + Model.name + "\"" : "Staff Registration")
                        </h3>
                    </div>
                    <form class="form-horizontal">
    <input type="hidden" id="hdnId" value="@(Model?.id ?? 0)" />
                        <div class="card-block">
                            <div class="row">

                                <div class="col-md-2"></div>

                                <div class="col-md-6">
                                    <input type="hidden" id="hdnId" value="@(Model?.id ?? 0)" />
                            <div class="form-group row">
                                        <div class="col-md-4"></div>
                                        <div class="col-md-8" style="text-align:center;">
                                            <input style="display:none" name="file" id="input-image-hidden"
                                                   onchange="encodeImgtoBase64(this);"
                                                   type="file" accept="image/jpeg, image/png">

                                            <img id="previewing" name="previewing" src="~/img/dummy_img.png"
                                                 style="margin-top:20px; height:128px; width:128px;cursor:pointer;object-fit:cover"
                                                 onclick="HandleBrowseClick('input-image-hidden');"
                                                 title="Click to Change the Photo."
                                                 class="profile-user-img img-responsive img-circle"
                                                 alt="User profile picture">

                                            <div><center>Photo</center></div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Staff Name:</label>
                                        <div class="col-md-8">
                                            <input type="text" class="form-control" id="txtStaffName" value="@(Model?.name ?? "")" required @(isEdit ? "readonly" : "")>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Email:</label>
                                        <div class="col-md-8">
                                            <input type="email" class="form-control" id="txtEmail" value="@(Model?.email ?? "")" required>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Staff Role:</label>
                                        <div class="col-md-8">
                                            <select class="form-select form-control" id="cboStaffRole" required>
                                                <option value="">Choose</option>
                                            </select> <!-- value will be set after roles loaded -->
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Date of Birth:</label>
                                        <div class="col-md-8">
                                            <input type="date" class="form-control" id="txtBirthDate" value="@(Model?.birth_of_date?.ToString("yyyy-MM-dd") ?? "")">
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label text-right">Phone No:</label>
                                        <div class="col-md-8">
                                            <input type="text" class="form-control" id="txtPhone" value="@(Model?.phone_no ?? "")">
                                            <small class="text-danger" id="phoneError"></small>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label text-right">Address:</label>
                                        <div class="col-md-8">
                                            <textarea class="form-control" id="txtAddress">@(Model?.address ?? "")</textarea>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Password:</label>
                                        <div class="col-md-8">
                                            <input type="@(isEdit ? "text" : "password")" class="form-control" id="txtPassword" value="@(Model?.password ?? "")">
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4"></div>
                                        <div class="col-md-8">
                                            @if (!isEdit)
                                        {
                                            <button type="button" class="btn btn-success float-right" onclick="saveStaff()">
                                                Create
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-primary float-right" onclick="saveStaff()">
                                                Update
                                            </button>
                                            <span class="text-muted ml-2">(Name is read-only)</span>
                                        }
                                        </div>
                                    </div>

                                </div>

                                <div class="col-md-4"></div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<script>

               $(document).ready(function () {
        loadRoles();
    });

    function loadRoles() {

        $.ajax({
            type: "GET",
            url: "/api/get_all_roles",
            success: function (data) {

                $("#cboStaffRole").empty();
                $("#cboStaffRole").append('<option value="">Choose</option>');

                $.each(data.roles, function (i, role) {

                    $("#cboStaffRole").append(
                        '<option value="' + role.id + '">' +
                            role.role_name +
                        '</option>'
                    );

                });
                // if editing, pick existing role
                @if(Model != null && Model.role_id > 0){
                    <text>$("#cboStaffRole").val("@Model.role_id");</text>
                }
            },

            error: function () {
                alert("Cannot load roles");
            }
        });

    }
        $("#txtPhone").on("input", function () {

        let phone = $(this).val();

        phone = phone.replace(/[^0-9]/g, '');
        $(this).val(phone);

        if (phone.length < 11) {
            $("#phoneError").text("Phone must be at least 11 digits");
        } else {
            $("#phoneError").text("");
        }

    });

        function saveStaff(){

        var obj = {
            id: parseInt($("#hdnId").val()),
            name: $("#txtStaffName").val(),
            email: $("#txtEmail").val(),
            birth_of_date: $("#txtBirthDate").val(),
            password: $("#txtPassword").val(),
            phone_no: $("#txtPhone").val(),
            address: $("#txtAddress").val(),
            role_id: parseInt($("#cboStaffRole").val())
};
        console.log(obj);

        $.ajax({
            type: "POST",
            url: "/api/set_staff",
            data: JSON.stringify(obj),
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function(res){

            if(res.message == "Success"){
                alert("Saved");
                clearForm();
                window.location = '/Entry/StaffList';
            }else{
                alert(res.message);
            }

        });
    }
        function clearForm() {

        $("#hdnId").val(0);
        $("#txtStaffName").val("");
        $("#txtEmail").val("");
        $("#txtBirthDate").val("");
        $("#txtPassword").val("");
        $("#txtPassword").val("");
        $("#cboStaffRole").val("");
        $("#txtAddress").val("");
        $("#txtPhone").val("");
    }
</script>

