@model FoodOutlet.Models.Staff
@{
    bool isEdit = Model != null && Model.id > 0;
    ViewData["Title"] = isEdit ? Model.name : "Registration";
}


<div class="content-header">
    <div class="container-fluid">
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12 col-sm-12 col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">
                            @(isEdit ? "Edit \"" + Model.name + "\"" : "Staff Registration")
                        </h3>
                    </div>
                    <form class="form-horizontal">
                        <input type="hidden" id="hdnId" value="@(Model?.id ?? 0)" />
                        <div class="card-block">
                            <div class="row">

                                <div class="col-md-2"></div>

                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4"></div>
                                        <div class="col-md-8" style="text-align:center;">
                                            <input style="display:none" name="file" id="input-image-hidden"
                                                   onchange="encodeImgtoBase64(this);"
                                                   type="file" accept="image/jpeg, image/png">

                                            <img id="previewing" name="previewing" src="~/img/dummy_img.png"
                                                 style="margin-top:20px; height:128px; width:128px;cursor:pointer;object-fit:cover"
                                                 onclick="HandleBrowseClick('input-image-hidden');"
                                                 title="Click to Change the Photo."
                                                 class="profile-user-img img-responsive img-circle"
                                                 alt="User profile picture">

                                            <div><center>Photo</center></div>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Staff Name:</label>
                                        <div class="col-md-8">
                                            <input type="text" class="form-control" id="txtStaffName" value="@(Model?.name ?? "")" required @(isEdit ? "readonly" : "")>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Email:</label>
                                        <div class="col-md-8">
                                            <input type="email" class="form-control" id="txtEmail" value="@(Model?.email ?? "")" required>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Staff Role:</label>
                                        <div class="col-md-8">
                                            <select class="form-select form-control" id="cboStaffRole" required>
                                                <option value="">Choose</option>
                                            </select> <!-- value will be set after roles loaded -->
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Date of Birth:</label>
                                        <div class="col-md-8">
                                            <input type="date" class="form-control" id="txtBirthDate" value="@(Model?.birth_of_date?.ToString("yyyy-MM-dd") ?? "")">
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label text-right">Phone No:</label>
                                        <div class="col-md-8">
                                            <input type="text" class="form-control" id="txtPhone" value="@(Model?.phone_no ?? "")">
                                            <small class="text-danger" id="phoneError"></small>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label text-right">Address:</label>
                                        <div class="col-md-8">
                                            <textarea class="form-control" id="txtAddress">@(Model?.address ?? "")</textarea>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label class="col-md-4 col-form-label" style="text-align:right;">Password:</label>
                                        <div class="col-md-8">
                                            <input type="@(isEdit ? "text" : "password")" class="form-control" id="txtPassword" value="@(Model?.password ?? "")">
                                        </div>
                                    </div>
                                    
                                    <div class="form-group row">
                                        <div class="col-md-9 offset-md-3 text-right">
                                            @if (isEdit)
                                            {
                                                <button id="btnSave" class="btn btn-success" onclick="saveStaff()">
                                                    <i class="fas fa-check"></i>Update
                                                </button>
                                                <a class="btn btn-secondary ml-2" asp-controller="Entry" asp-action="StaffList">Back to Staff List</a>
                                                
                                            }
                                            else
                                            {
                                                <button id="btnSave" class="btn btn-success" onclick="saveRsaveStaffecipe()">
                                                    <i class="fas fa-check"></i>Create
                                                </button>
                                                <a class="btn btn-secondary ml-2" asp-controller="Entry" asp-action="Registration">Clear</a>
                                            }
                                        </div>
                                    </div>
                                <div class="col-md-4"></div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    $(document).ready(function () {
        // start loader using same pattern as other pages
        loadRoles();
    });

    // Robust loader copied from prior implementation but improved for debugging and resilience.
    function loadRoles() {
        console.log('loadRoles: requesting /api/get_all_roles');
        $.ajax({
            type: "GET",
            url: "/api/get_all_roles",
            dataType: "json"
        })
        .done(function (data) {
            try {
                console.log('loadRoles: response', data);
                var list = data && data.roles ? data.roles : data;

                var $sel = $("#cboStaffRole");
                $sel.empty();
                $sel.append('<option value="">Choose</option>');

                if (Array.isArray(list) && list.length) {
                    $.each(list, function (i, role) {
                        // be defensive in property names
                        var id = role.id ?? role.role_id ?? role.Id;
                        var name = role.role_name ?? role.name ?? role.RoleName ?? '';
                        $sel.append($('<option>').val(id).text(name));
                    });

                    // if editing, pick existing role
                    @if(Model != null && Model.role_id > 0){
                        <text>console.log('loadRoles: selecting role @Model.role_id'); $sel.val('@Model.role_id');</text>
                    }
                } else {
                    console.warn('loadRoles: no roles returned', list);
                    // still attempt to select server-provided value if present
                    @if(Model != null && Model.role_id > 0){
                        <text>console.log('loadRoles: fallback select role @Model.role_id'); $sel.val('@Model.role_id');</text>
                    }
                }
            } catch (ex) {
                console.error('loadRoles: exception processing response', ex);
            }
        })
        .fail(function (xhr, status, err) {
            console.error('loadRoles: AJAX failed', status, err, xhr.responseText);
            alert("Cannot load roles");
            // attempt fallback selection of server-side rendered option (if any)
            @if(Model != null && Model.role_id > 0){
                <text>$("#cboStaffRole").val("@Model.role_id");</text>
            }
        });
    }

    $("#txtPhone").on("input", function () {

        let phone = $(this).val();

        phone = phone.replace(/[^0-9]/g, '');
        $(this).val(phone);

        if (phone.length < 11) {
            $("#phoneError").text("Phone must be at least 11 digits");
        } else {
            $("#phoneError").text("");
        }

    });

    function saveStaff(){

        var obj = {
            id: parseInt($("#hdnId").val()),
            name: $("#txtStaffName").val(),
            email: $("#txtEmail").val(),
            birth_of_date: $("#txtBirthDate").val(),
            password: $("#txtPassword").val(),
            phone_no: $("#txtPhone").val(),
            address: $("#txtAddress").val(),
            role_id: parseInt($("#cboStaffRole").val() || 0)
        };
        console.log('saveStaff: payload', obj);

        $.ajax({
            type: "POST",
            url: "/api/set_staff",
            data: JSON.stringify(obj),
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function(res){

            if(res.message == "Success"){
                alert("Saved");
                clearForm();
                window.location = '/Entry/StaffList';
            }else{
                alert(res.message);
            }

        }).fail(function(xhr, status, err){
            console.error('saveStaff: failed', status, err, xhr.responseText);
            alert('Save failed');
        });
    }
    function clearForm() {

        $("#hdnId").val(0);
        $("#txtStaffName").val("");
        $("#txtEmail").val("");
        $("#txtBirthDate").val("");
        $("#txtPassword").val("");
        $("#txtPassword").val("");
        $("#cboStaffRole").val("");
        $("#txtAddress").val("");
        $("#txtPhone").val("");
    }
</script>