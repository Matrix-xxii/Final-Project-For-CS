@{
    ViewData["Title"] = "Staff List";
}

<style>
    /* Staff List Table */
    #staffTable {
        table-layout: fixed;
        width: 100%;
        border-collapse: collapse;
    }

    #staffTable thead th {
        padding: 12px;
        border: 1px solid #dee2e6;
        text-align: left;
        vertical-align: middle;
        background-color: #f8f9fa;
        font-weight: 600;
        font-size: 14px;
    }

    #staffTable tbody td {
        padding: 12px;
        border: 1px solid #dee2e6;
        vertical-align: middle;
        font-size: 14px;
    }

    /* Column widths */
    #staffTable thead th:nth-child(1),
    #staffTable tbody td:nth-child(1) {
        width: 60px;
        text-align: center;
    }

    #staffTable thead th:nth-child(2),
    #staffTable tbody td:nth-child(2) {
        width: 90px;
        text-align: center;
    }

    #staffTable thead th:nth-child(3),
    #staffTable tbody td:nth-child(3) {
        width: 130px;
    }

    #staffTable thead th:nth-child(4),
    #staffTable tbody td:nth-child(4) {
        width: 150px;
    }

    #staffTable thead th:nth-child(5),
    #staffTable tbody td:nth-child(5) {
        width: 120px;
    }

    #staffTable thead th:nth-child(6),
    #staffTable tbody td:nth-child(6) {
        width: 130px;
    }

    #staffTable thead th:nth-child(7),
    #staffTable tbody td:nth-child(7) {
        width: 110px;
    }

    #staffTable thead th:nth-child(8),
    #staffTable tbody td:nth-child(8) {
        width: 100px;
        text-align: center;
    }

    #staffTable thead th:nth-child(9),
    #staffTable tbody td:nth-child(9) {
        width: 100px;
        text-align: center;
    }

    /* Photo cell styling */
    .photo-cell {
        padding: 6px !important;
    }

    .staff-photo-wrapper {
        width: 55px;
        height: 55px;
        margin: 0 auto;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #007bff;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f0f0f0;
        font-weight: bold;
        font-size: 16px;
        color: white;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .staff-photo-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .staff-initials {
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Action buttons */
    .action-btn {
        width: 34px;
        height: 34px;
        padding: 5px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin: 0 2px;
        font-size: 13px;
    }

    /* Search and filter section */
    .staff-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 15px;
        flex-wrap: wrap;
    }

    .staff-info {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 350px;
    }

    .search-box input {
        width: 100%;
        padding: 8px 12px 8px 36px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
    }

    .search-box input:focus {
        border-color: #007bff;
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,0.1);
    }

    .search-box i {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        pointer-events: none;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #999;
    }

    .empty-state i {
        font-size: 48px;
        margin-bottom: 15px;
        opacity: 0.5;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .staff-controls {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            max-width: 100%;
        }

        #staffTable {
            font-size: 12px;
        }

        #staffTable thead th,
        #staffTable tbody td {
            padding: 8px;
        }

        #staffTable thead th:nth-child(6),
        #staffTable tbody td:nth-child(6) {
            display: none;
        }

        .action-btn {
            width: 30px;
            height: 30px;
            font-size: 12px;
        }

        .staff-photo-wrapper {
            width: 45px;
            height: 45px;
            font-size: 14px;
        }
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Staff List</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title font-weight-bold">Staff Management</h3>
            </div>

            <div class="card-body">
                <!-- Search and Info Controls -->
                <div class="staff-controls">
                    <div class="staff-info">
                        <span id="staffCount">Total Staff: 0</span>
                    </div>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="staffFilter" placeholder="Filter by name or email..." />
                    </div>
                </div>

                <!-- Staff Table -->
                <div style="overflow-x: auto;">
                    <table id="staffTable" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Photo</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Address</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>

                <!-- Empty State -->
                <div id="emptyState" class="empty-state" style="display: none;">
                    <i class="fas fa-inbox"></i>
                    <p>No staff found</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    let staffData = [];

    function editStaff(id) {
        window.location = '/Entry/Registration?id=' + id;
    }

    function deleteStaff(id) {
        if (!confirm('Are you sure you want to delete this staff?')) return;
        
        $.ajax({
            type: 'POST',
            url: '/api/delete_staff',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json',
            dataType: 'json',
            headers: {
                'X-CSRF-TOKEN': $('input[name="__RequestVerificationToken"]').val()
            }
        }).done(function (res) {
            if (res.message === 'Success') {
                alert('Staff deleted successfully');
                loadStaff();
            } else {
                alert('Error: ' + res.message);
            }
        }).fail(function () {
            alert('Failed to delete staff');
        });
    }

    function getInitials(name) {
        if (!name) return '?';
        return name.split(' ')
            .map(word => word.charAt(0).toUpperCase())
            .join('')
            .substring(0, 2);
    }

    function getStaffPhotoHtml(imagePath, staffName) {
        // If no image or empty path, show initials
        if (!imagePath || imagePath.trim() === '') {
            const initials = getInitials(staffName);
            return `<div class="staff-photo-wrapper">
                        <span class="staff-initials">${initials}</span>
                    </div>`;
        }

        // Show image file
        return `<div class="staff-photo-wrapper">
                    <img src="${imagePath}" 
                         alt="${staffName}" 
                         style="width:100%; height:100%; object-fit:cover; border-radius:50%;" 
                         onerror="this.parentElement.innerHTML='<span class=&quot;staff-initials&quot;>${getInitials(staffName)}</span>';" />
                </div>`;
    }

    function renderStaffTable() {
        const tableBody = $('#staffTable tbody');
        const emptyState = $('#emptyState');

        if (staffData.length === 0) {
            tableBody.empty();
            emptyState.show();
            return;
        }

        emptyState.hide();
        tableBody.empty();

        $('#staffCount').text(`Total Staff: ${staffData.length}`);

        staffData.forEach(function (staff, idx) {
            let statusBadge = staff.status === "In Service"
                ? '<span class="badge badge-success">In Service</span>'
                : '<span class="badge badge-danger">Resign</span>';

            let photoHtml = getStaffPhotoHtml(staff.photo, staff.name);

            let row = $('<tr>').append(
                $('<td>').text(idx + 1).css('text-align', 'center'),
                $('<td>').addClass('photo-cell').html(photoHtml),
                $('<td>').text(staff.name || '-'),
                $('<td>').text(staff.email || '-'),
                $('<td>').text(staff.phone_no || '-'),
                $('<td>').text(staff.address || '-'),
                $('<td>').text(staff.role_name || 'N/A'),
                $('<td>').html(statusBadge).css('text-align', 'center'),
                $('<td>').css('text-align', 'center').html(`
                    <div style="white-space: nowrap;">
                        <button class="action-btn btn btn-warning btn-sm" title="Edit" onclick="editStaff(${staff.id})">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn btn btn-danger btn-sm" title="Delete" onclick="deleteStaff(${staff.id})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `)
            );
            tableBody.append(row);
        });
    }

    function loadStaff() {
        $.ajax({
            url: '/api/get_all_staffs',
            type: 'GET',
            cache: false,
            success: function (response) {
                staffData = response.staff || [];
                console.log('Staff loaded:', staffData.length);
                if (staffData.length > 0) {
                    console.log('First staff photo length:', staffData[0].photo ? staffData[0].photo.length : 'no photo');
                }
                renderStaffTable();
            },
            error: function (err) {
                console.error('Error loading staff:', err);
                $('#staffTable tbody').empty();
                $('#emptyState').show().find('p').text('Failed to load staff list');
            }
        });
    }

    $(document).ready(function () {
        loadStaff();

        $('#staffFilter').on('keyup', function () {
            let filterValue = $(this).val().toLowerCase();
            let visibleCount = 0;

            $('#staffTable tbody tr').each(function () {
                let text = $(this).text().toLowerCase();
                if (filterValue === '' || text.includes(filterValue)) {
                    $(this).show();
                    visibleCount++;
                } else {
                    $(this).hide();
                }
            });

            if (visibleCount === 0) {
                $('#staffCount').text('No staff found');
            } else {
                let totalStaff = $('#staffTable tbody tr').length;
                $('#staffCount').text(`Showing ${visibleCount} of ${totalStaff} staff`);
            }
        });
    });
</script>
