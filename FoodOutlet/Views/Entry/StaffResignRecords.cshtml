@{
    ViewData["Title"] = "Resign Messages";
}

<div class="content-header">
    <div class="container-fluid"></div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold">Resign Messages</h3>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div><span id="resignCount" class="font-weight-bold"></span></div>
                    <div>
                        <input type="text" id="resignFilter" class="form-control" placeholder="Filter resign messages..." style="width: 220px; display: inline-block;" />
                    </div>
                </div>
                <table id="resignTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Reason</th>
                            <th>Resign Date</th>
                            <th>Approval</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    $(document).ready(function () {
        loadRecords();
    });

    function loadRecords() {
        $.get('/api/get_resigned_staff', function (response) {
            var list = response.records || [];
            let rows = '';

            list.forEach(function (item, idx) {
                rows += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${item.name || '-'}</td>
                        <td>${item.email || '-'}</td>
                        <td>${item.role_name || '-'}</td>
                        <td>${item.reason || '-'}</td>
                        <td>${item.resign ? new Date(item.resign).toLocaleDateString() : '-'}</td>
                        <td>${item.approval_status || 'Pending'}</td>
                    </tr>`;
            });

            if (!rows) {
                rows = '<tr><td colspan="7" class="text-center text-muted">No resign records found</td></tr>';
            }

            $('#resignTable tbody').html(rows);
            $('#resignCount').text(`Total Messages: ${list.length}`);
        }).fail(function () {
            alert('Failed to load resign records');
        });
    }

    $('#resignFilter').on('keyup', function () {
        var value = $(this).val().toLowerCase();
        $('#resignTable tbody tr').filter(function () {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
        });
    });
</script>
}