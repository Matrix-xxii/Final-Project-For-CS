@{
    ViewData["Title"] = "Role";
}


<div class="content-header">
    <div class="container-fluid">
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">Role Registration</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group row">

                            <label class="col-md-2 col-form-label font-weight-bold">Role</label>
                            <div class="col-md-5">
                                <input id="txtRoleName" type="text" class="form-control" placeholder="Enter role name">
                            </div>
                            <div class="col-md-2">
                                <button id="btnCreateRole" class="btn btn-success" onclick="createRole()">Create</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">Role List</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped mb-0" id="myTable">
                            <thead>
                                <tr>
                                    <th style="width: 80px;">No.</th>
                                    <th style="width: 200px;">Role</th>
                                    <th class="text-center mb-0" style="width: 120px;">Action</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    
    $(function(){
        GetAllRoles();
    });

    function GetAllRoles(){
        $("#myTable").find("tbody").find("tr").remove();
        $.ajax({
            type:"GET",
            url :"/api/get_all_roles"
        }).done(function(data){
            $.each(data.roles, function(i,v){
                var num = i + 1;
                $("#myTable tbody").append( 
        "<tr>" +
            "<td>" + num + "</td>" +
            "<td>" + v.role_name + "</td>" +
            "<td class='text-center'>" +
                "<button class='btn btn-danger btn-sm' onclick='deleteRole(" + v.id + ")'><i class='fas fa-trash'></i></button>" +
            "</td>" +
        "</tr>"
    );
            });
        });
    }

    function deleteRole(id){
        if(!confirm('Are you sure you want to delete this role?')) return;
        $.ajax({
            type: "POST",
            url: "/api/delete_role",
            data: JSON.stringify({ id: id }),
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function(res){
            if(res.message == "Success"){
                alert('Deleted successfully.');
                GetAllRoles();
            } else {
                alert(res.message);
            }
        });
    }
    
    function createRole(){
        var name = $("#txtRoleName").val().trim();
        if(name === ""){
            alert('Role name cannot be empty');
            return;
        }
        $.ajax({
            type: "POST",
            url: "/api/set_role",
            data: JSON.stringify({ role_name: name }),
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function(res){
            if(res.message == "Success"){
                $("#txtRoleName").val("");
                alert('Created successfully.');
                GetAllRoles();
            } else {
                alert(res.message);
            }
        });
    }
    
</script>

