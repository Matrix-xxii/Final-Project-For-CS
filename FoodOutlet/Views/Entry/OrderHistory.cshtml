@{
    ViewData["Title"] = "Order History";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Order History</h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold">All Orders</h3>
            </div>
            <div class="card-body">
                <table id="orderHistoryTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Order ID</th>
                            <th>Table</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Created At</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    $(document).ready(function () {
        loadOrderHistory();
    });

    function loadOrderHistory() {
        $.ajax({
            url: '/api/admin/order_history',
            method: 'GET',
            dataType: 'json',
            cache: false
        }).done(function (res) {
            const orders = (res && (res.orders || res.Orders)) ? (res.orders || res.Orders) : [];
            let html = '';

            orders.forEach(function (o, idx) {
                const oid = o.order_id ?? o.orderId;
                const label = o.table_label ?? o.tableLabel ?? '-';
                const st = o.status ?? o.Status ?? '-';
                const items = o.items_summary ?? o.itemsSummary ?? '-';
                const totalAmt = parseFloat(o.order_total ?? o.orderTotal ?? 0).toLocaleString();
                const created = o.created_at ?? o.createdAt;
                const dt = created ? new Date(created).toLocaleString() : '-';
                html += `<tr>
                    <td>${idx + 1}</td>
                    <td>${oid}</td>
                    <td>${label}</td>
                    <td>${st}</td>
                    <td>${items}</td>
                    <td>${totalAmt} MMK</td>
                    <td>${dt}</td>
                </tr>`;
            });

            if (!html) {
                html = '<tr><td colspan="7" class="text-center text-muted">No order history found.</td></tr>';
            }

            $('#orderHistoryTable tbody').html(html);
        }).fail(function (xhr) {
            console.error('Order history failed', xhr.status, xhr.responseText);
            $('#orderHistoryTable tbody').html(
                '<tr><td colspan="7" class="text-center text-danger">' +
                    (xhr.status === 404 ? 'API not found. Please redeploy the latest server code.' : 'Failed to load order history (HTTP ' + xhr.status + ').') +
                    '</td></tr>');
            alert('Failed to load order history');
        });
    }
</script>
}