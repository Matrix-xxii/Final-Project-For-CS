@{
    ViewData["Title"] = "Inventory";
}

<div class="content-header">
    <div class="container-fluid"></div>
</div>

<section class="content" id="inventoryMain">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold mb-0">Inventory(Stock Control)</h3>
                <button class="btn btn-success ml-auto" id="btnAdd" onclick="openForm()">Add Stock</button>
            </div>

            <div class="card-body">
                <table class="table table-striped" id="inventoryTable">
                    <thead>
                        <tr>
                            <th style="width:6%;">No</th>
                            <th style="width:80px;">Image</th>
                            <th>Recipe</th>
                            <th style="width:120px;">Qty</th>
                            <th style="width:120px;" class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<!-- Overlay shown when modal is open -->
<div id="modalOverlay" style="display:none;"></div>

<!-- Modal-->
<div class="modal-custom" id="inventoryModal" aria-hidden="true" style="display:none;">
  <div class="modal-dialog-custom" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Inventory</h5>
        <button type="button" class="close" onclick="closeForm()" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <form id="inventoryForm" onsubmit="return false;">
            <input type="hidden" id="invId" value="0" />
            <div class="form-group">
                <label>Recipe</label>
                <select id="ddlRecipe" class="form-control"></select>
            </div>
            <div class="form-group">
                <label>Quantity</label>
                <input id="txtQty" type="number" class="form-control" min="0" />
            </div>
        </form>
      </div>
      <div class="modal-footer">
        <button id="btnSaveInventory" type="button" class="btn btn-primary" onclick="saveInventory()">Save</button>
        <button type="button" class="btn btn-secondary" onclick="closeForm()">Cancel</button>
      </div>
    </div>
  </div>
</div>

<style>
    /* blur when modal open */
    #inventoryMain.blurred {
        filter: blur(4px);
        pointer-events: none;
        user-select: none;
    }

    /* overlay (dark translucent background) */
    #modalOverlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 2000;
    }

    /* modal custom styling (centered, above overlay) */
    .modal-custom {
        position: fixed;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: 2001;
        max-width: 520px;
        width: 90%;
        display: block;
    }

    .modal-dialog-custom { max-width: 520px; margin: 0 auto; }

    .modal-content {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.2);
        overflow: hidden;
    }

    .modal-header, .modal-footer { padding: 12px 16px; }
    .modal-body { padding: 16px; }

    .img-inventory { max-width:80px; max-height:60px; border-radius: 4px; object-fit: cover; }
</style>

@section Scripts {
<script>
    $(function(){
        loadRecipesForDropdown();
        loadInventories();
    });

    function loadRecipesForDropdown() {
        $.get('/api/get_all_recipes', function(res){
            var list = res.recipes || [];
            var $ddl = $('#ddlRecipe');
            $ddl.empty();
            $ddl.append('<option value="">Choose recipe</option>');
            list.forEach(function(r){
                $ddl.append('<option value="' + r.id + '">' + (r.recipe_name || '') + '</option>');
            });
        });
    }

    function getImageUrl(imagePath) {
        // If image path is empty or null, return dash
        if (!imagePath) {
            return '';
        }

        // If already a data URL, use as-is
        if (imagePath.startsWith('data:')) {
            return `<img src="${imagePath}" class="img-inventory" alt="Recipe Image" />`;
        }

        // If it's a full URL, use as-is
        if (imagePath.startsWith('http')) {
            return `<img src="${imagePath}" class="img-inventory" alt="Recipe Image" />`;
        }

        // If it's just a filename or partial path, construct the full path
        let fullPath = imagePath;
        if (!imagePath.startsWith('/')) {
            fullPath = '/uploads/recipes/' + imagePath;
        } else if (!imagePath.includes('/uploads/recipes/')) {
            fullPath = '/uploads/recipes/' + imagePath.split('/').pop();
        }

        return `<img src="${fullPath}" class="img-inventory" alt="Recipe Image" onerror="this.src=''" />`;
    }

    function loadInventories(){
        $.get('/api/get_all_inventories', function(res){
            var rows = '';
            var list = res.inventories || [];
            list.forEach(function(item, idx){
                var invId = item.inventory_id || 0;
                var imgHtml = getImageUrl(item.recipe_img || '');
                rows += '<tr>' +
                    '<td>' + (idx+1) + '</td>' +
                    '<td>' + imgHtml + '</td>' +
                    '<td>' + (item.recipe_name || '') + '</td>' +
                    '<td>' + (item.stock_qty || 0) + '</td>' +
                    '<td class="text-center">' +
                        '<button class="btn btn-warning btn-sm" onclick="editInventory(' + invId + ',' + item.recipe_id + ',' + (item.stock_qty||0) + ')"><i class="fas fa-edit"></i></button> ' +
                        (invId ? ('<button class="btn btn-danger btn-sm" onclick="deleteInventory(' + invId + ')"><i class="fas fa-trash"></i></button>') : '') +
                    '</td>' +
                '</tr>';
            });
            $('#inventoryTable tbody').html(rows || '<tr><td colspan="5" class="text-center text-muted">No inventory items</td></tr>');
        });
    }

    function openForm(){
        $('#inventoryModal').data('mode', 'add');
        $('#invId').val(0);
        $('#ddlRecipe').val('');
        $('#txtQty').val(0);
        $('#btnSaveInventory').prop('disabled', false);
        $('#modalOverlay').show();
        $('#inventoryModal').show().attr('aria-hidden', 'false');
        $('#inventoryMain').addClass('blurred');
    }
    
    function closeForm(){
        $('#modalOverlay').hide();
        $('#inventoryModal').hide().attr('aria-hidden', 'true');
        $('#inventoryMain').removeClass('blurred');
    }

    function editInventory(invId, recipeId, qty){
        $('#inventoryModal').data('mode', 'edit');
        $('#invId').val(invId || 0);
        $('#ddlRecipe').val(recipeId || '');
        $('#txtQty').val(qty || 0);

        $('#modalOverlay').show();
        $('#inventoryModal').show().attr('aria-hidden', 'false');
        $('#inventoryMain').addClass('blurred');

        if (!invId) {
            $('#btnSaveInventory').prop('disabled', false);
            return;
        }

        $('#btnSaveInventory').prop('disabled', true);
        $.get('/api/get_inventory_by_id?id=' + invId)
            .done(function(res){
                if (res) {
                    $('#invId').val(res.id || 0);
                    $('#ddlRecipe').val(res.recipe_id || '');
                    $('#txtQty').val(res.stock_qty || 0);
                }
            })
            .always(function(){
                $('#btnSaveInventory').prop('disabled', false);
            });
    }

    function saveInventory(){
        $('#btnSaveInventory').prop('disabled', true);

        var obj = {
            id: parseInt($('#invId').val()) || 0,
            recipe_id: parseInt($('#ddlRecipe').val() || 0),
            stock_qty: parseInt($('#txtQty').val() || 0)
        };

        if(!obj.recipe_id){ alert('Choose recipe'); $('#btnSaveInventory').prop('disabled', false); return; }

        $.ajax({
            type: 'POST',
            url: '/api/set_inventory',
            data: JSON.stringify(obj),
            contentType: 'application/json; charset=utf-8'
        }).done(function(res){
            if(res && (res.message == 'Success' || res.message == 'Updated')){
                closeForm();
                loadInventories();
            } else {
                alert(res ? res.message : 'Save failed');
            }
        }).fail(function(){
            alert('Save failed');
        }).always(function(){
            $('#btnSaveInventory').prop('disabled', false);
        });
    }

    function deleteInventory(id){
        if(!confirm('Delete this inventory row?')) return;
        $.ajax({
            type:'POST',
            url:'/api/delete_inventory',
            data: JSON.stringify({ id: id }),
            contentType:'application/json; charset=utf-8'
        }).done(function(res){
            if(res.message == 'Success') loadInventories(); else alert(res.message);
        }).fail(function(){ alert('Delete failed'); });
    }

    function getRecipePhotoFrame(imagePath, recipeName) {
        return PhotoFrameHelper.PhotoFrameHtml(
            imagePath || '/img/placeholder.png',
            "4:3",
            80,
            recipeName,
            "rounded shadow-sm"
        );
    }

    $(document).ready(function () {
        $.ajax({
            url: '/api/get_all_inventories',
            type: 'GET',
            success: function (response) {
                let rows = "";
                var list = response.inventories || [];
                list.forEach(function (item, idx) {
                    let photoFrame = getRecipePhotoFrame(item.recipe_img, item.recipe_name);

                    rows += `
                        <tr>
                            <td>${idx + 1}</td>
                            <td>${photoFrame}</td>
                            <td>${item.recipe_name}</td>
                            <td><input type="number" value="${item.stock_qty}" min="0" /></td>
                            <td>
                                <button class="btn btn-primary btn-sm" onclick="updateInventory(${item.recipe_id})">
                                    <i class="fas fa-save"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $("#inventoryTable tbody").html(rows);
            }
        });
    });
</script>
}