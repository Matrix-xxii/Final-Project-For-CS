@{
    ViewData["Title"] = "Recipe List";
}

<style>
    .img-thumb { 
        max-width: 80px; 
        max-height: 60px; 
        display: block; 
        object-fit: cover; 
        border-radius: 4px; 
    }
    
    .action-btn { 
        width: 36px; 
        height: 36px; 
        border-radius: 6px; 
        margin: 0 3px; 
        border: none; 
        cursor: pointer; 
        padding: 4px;
    }
    
    .desc-preview { 
        display: inline; 
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        max-width: 480px; 
    }

    /* Fix DataTables layout shift */
    #recipeTable {
        table-layout: fixed;
        width: 100%;
    }

    #recipeTable thead th {
        overflow: hidden;
    }

    #recipeTable tbody td {
        overflow: hidden;
        word-wrap: break-word;
    }

    /* Image column */
    #recipeTable thead th:nth-child(2),
    #recipeTable tbody td:nth-child(2) {
        width: 80px;
        text-align: center;
    }

    /* Action column - now column 6 instead of 7 */
    #recipeTable thead th:nth-child(6),
    #recipeTable tbody td:nth-child(6) {
        width: 100px;
        text-align: center;
    }

    /* Price column */
    #recipeTable thead th:nth-child(5),
    #recipeTable tbody td:nth-child(5) {
        text-align: right;
        width: 110px;
    }

    /* No column */
    #recipeTable thead th:nth-child(1),
    #recipeTable tbody td:nth-child(1) {
        width: 50px;
        text-align: center;
    }

    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_paginate {
        margin-bottom: 15px;
    }
</style>

<div class="content-header">
    <div class="container-fluid"></div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold">Recipe List</h3>
            </div>

            <div class="card-body">
                <table class="table table-striped" id="recipeTable" style="width:100%">
                    <thead>
                        <tr>
                            <th>No</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price (MMK)</th>
                            <th>Description</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    let recipeTable;

    $(document).ready(function () {
        recipeTable = $('#recipeTable').DataTable({
            pageLength: 10,
            lengthChange: false,
            searching: true,
            ordering: true,
            pagingType: "simple_numbers",
            responsive: false,
            autoWidth: false,
            columnDefs: [
                { targets: 0, orderable: false, width: '50px' },
                { targets: 1, orderable: false, width: '80px' },
                { targets: 6, orderable: false, width: '100px' }  // Action column is now 6 (was 7)
            ]
        });

        loadRecipes();
    });

    function escapeHtml(text) {
        if (!text) return '';
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function makeDescriptionCell(text, maxLen = 60) {
        text = text || '';
        if (text.length <= maxLen) {
            return `<span class="desc-preview">${escapeHtml(text)}</span>`;
        }
        const preview = text.substring(0, maxLen).trimEnd();
        const dots = ' .....';
        return `<span class="desc-preview">${escapeHtml(preview)}${dots}</span>`;
    }

    function getImageUrl(imagePath) {
        // If image path is empty or null, return placeholder
        if (!imagePath) {
            return '<span class="text-muted">-</span>';
        }

        // If already a data URL, use as-is
        if (imagePath.startsWith('data:')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe Image" />`;
        }

        // If it's a full URL, use as-is
        if (imagePath.startsWith('http')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe Image" />`;
        }

        // If it's just a filename or partial path, construct the full path
        let fullPath = imagePath;
        if (!imagePath.startsWith('/')) {
            fullPath = '/uploads/recipes/' + imagePath;
        } else if (!imagePath.includes('/uploads/recipes/')) {
            fullPath = '/uploads/recipes/' + imagePath.split('/').pop();
        }

        return `<img src="${fullPath}" class="img-thumb" alt="Recipe Image" onerror="this.onerror=null; this.src='/img/placeholder.png'" />`;
    }

    function formatDate(dateString) {
        if (!dateString) return '-';
        try {
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        } catch (e) {
            return '-';
        }
    }

    function loadRecipes() {
        $.get('/api/get_all_recipes')
            .done(function (data) {
                const list = data.recipes || [];
                recipeTable.clear();
                list.forEach(function (r, idx) {
                    const descHtml = makeDescriptionCell(r.description ?? '', 60);
                    const imgHtml = getImageUrl(r.recipe_img ?? '');
                    
                    recipeTable.row.add([
                        idx + 1,
                        imgHtml,
                        r.recipe_name ?? '',
                        r.category_name ?? '',
                        parseFloat(r.price || 0).toLocaleString(),
                        descHtml,
                        `<div class="text-center">
                            <button class="action-btn btn-edit btn btn-warning btn-sm" title="Edit" onclick="goEdit(${r.id})"><i class="fas fa-edit"></i></button>
                            <button class="action-btn btn-delete btn btn-danger btn-sm" title="Delete" onclick="deleteRecipe(${r.id})"><i class="fas fa-trash"></i></button>
                         </div>`
                    ]);
                });
                recipeTable.draw();
            })
            .fail(function () {
                alert('Failed to load recipes');
            });
    }

    function goEdit(id) {
        window.location = '/Entry/Recipe?id=' + id;
    }

    function deleteRecipe(id) {
        if (!confirm('Delete this recipe?')) return;
        $.ajax({
            type: 'POST',
            url: '/api/delete_recipe',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json'
        })
        .done(function (res) {
            if (res.message === 'Success') loadRecipes(); else alert(res.message);
        })
        .fail(function () {
            alert('Delete failed');
        });
    }

    function getRecipePhotoFrame(imagePath, recipeName) {
        return PhotoFrameHelper.PhotoFrameHtml(
            imagePath || '/img/placeholder.png',
            "4:3",
            80,
            recipeName,
            "rounded shadow-sm"
        );
    }

    $(document).ready(function () {
        $.ajax({
            url: '/api/get_all_recipes',
            type: 'GET',
            success: function (response) {
                let rows = "";
                var list = response.recipes || [];
                list.forEach(function (recipe, idx) {
                    let photoFrame = getRecipePhotoFrame(recipe.recipe_img, recipe.recipe_name);

                    rows += `
                        <tr>
                            <td>${idx + 1}</td>
                            <td>${photoFrame}</td>
                            <td>${recipe.recipe_name}</td>
                            <td>${recipe.category_name}</td>
                            <td>${recipe.price}</td>
                            <td>
                                <button class="btn btn-warning btn-sm" onclick="editRecipe(${recipe.id})">
                                    <i class="fas fa-edit"></i>
                                </button>           
                                <button class="btn btn-danger btn-sm" onclick="deleteRecipe(${recipe.id})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
                $("#recipeTable tbody").html(rows);
            }
        });
    });
</script>
}