@{
    ViewData["Title"] = "Recipe List";
}

<style>
    .img-thumb { max-width:80px; max-height:60px; display:block; object-fit: cover; border-radius: 4px; }
    .action-btn { width:36px;height:36px;border-radius:6px;margin:0 3px;border:none; cursor: pointer; }
    .desc-preview { display: inline; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 480px; }
</style>

<div class="content-header">
    <div class="container-fluid"></div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold">Recipe List</h3>
            </div>

            <div class="card-body">
                <table class="table table-striped" id="recipeTable" style="width:100%">
                    <thead>
                        <tr>
                            <th style="width:6%;">No</th>
                            <th style="width:11%;">Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price (MMK)</th>
                            <th>Description</th>
                            <th class="text-center" style="width:150px;">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    let recipeTable;

    $(document).ready(function () {
        recipeTable = $('#recipeTable').DataTable({
            pageLength: 10,
            lengthChange: false,
            searching: true,
            ordering: true,
            pagingType: "simple_numbers",
            responsive: true,
            autoWidth: false,
            columnDefs: [
                { targets: 0, orderable: false },
                { targets: 6, orderable: false }
            ]
        });

        loadRecipes();
    });

    function escapeHtml(text) {
        if (!text) return '';
        return text
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function makeDescriptionCell(text, maxLen = 60) {
        text = text || '';
        if (text.length <= maxLen) {
            return `<span class="desc-preview">${escapeHtml(text)}</span>`;
        }
        const preview = text.substring(0, maxLen).trimEnd();
        const dots = ' .....';
        return `<span class="desc-preview">${escapeHtml(preview)}${dots}</span>`;
    }

    function getImageUrl(imagePath) {
        // If image path is empty or null, return placeholder
        if (!imagePath) {
            return '<span class="text-muted">-</span>';
        }

        // If already a data URL, use as-is
        if (imagePath.startsWith('data:')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe Image" />`;
        }

        // If it's a full URL, use as-is
        if (imagePath.startsWith('http')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe Image" />`;
        }

        // If it's just a filename or partial path, construct the full path
        let fullPath = imagePath;
        if (!imagePath.startsWith('/')) {
            fullPath = '/uploads/recipes/' + imagePath;
        } else if (!imagePath.includes('/uploads/recipes/')) {
            fullPath = '/uploads/recipes/' + imagePath.split('/').pop();
        }

        return `<img src="${fullPath}" class="img-thumb" alt="Recipe Image" onerror="this.src='/img/placeholder.png'" />`;
    }

    function loadRecipes() {
        $.get('/api/get_all_recipes')
            .done(function (data) {
                const list = data.recipes || [];
                recipeTable.clear();
                list.forEach(function (r, idx) {
                    const descHtml = makeDescriptionCell(r.description ?? '', 60);
                    const imgHtml = getImageUrl(r.recipe_img ?? '');
                    
                    recipeTable.row.add([
                        idx + 1,
                        imgHtml,
                        r.recipe_name ?? '',
                        r.category_name ?? '',
                        parseFloat(r.price || 0).toLocaleString(),
                        descHtml,
                        `<div class="text-center">
                            <button class="action-btn btn-edit btn btn-warning btn-sm" title="Edit" onclick="goEdit(${r.id})"><i class="fas fa-edit"></i></button>
                            <button class="action-btn btn-delete btn btn-danger btn-sm" title="Delete" onclick="deleteRecipe(${r.id})"><i class="fas fa-trash"></i></button>
                         </div>`
                    ]);
                });
                recipeTable.draw();
            })
            .fail(function () {
                alert('Failed to load recipes');
            });
    }

    function goEdit(id) {
        window.location = '/Entry/Recipe?id=' + id;
    }

    function deleteRecipe(id) {
        if (!confirm('Delete this recipe?')) return;
        $.ajax({
            type: 'POST',
            url: '/api/delete_recipe',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json'
        })
        .done(function (res) {
            if (res.message === 'Success') loadRecipes(); else alert(res.message);
        })
        .fail(function () {
            alert('Delete failed');
        });
    }
</script>
}