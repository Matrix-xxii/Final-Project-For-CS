@{
    ViewData["Title"] = "Recipe List";
}

<style>
    /* Fix DataTables layout shift */
    #recipeTable {
        table-layout: fixed;
        width: 100%;
        border-collapse: collapse;
    }

    #recipeTable thead th {
        overflow: hidden;
        padding: 12px;
        border: 1px solid #dee2e6;
        text-align: left;
        vertical-align: middle;
        background-color: #f8f9fa;
        font-weight: 600;
    }

    #recipeTable tbody td {
        overflow: hidden;
        word-wrap: break-word;
        padding: 12px;
        border: 1px solid #dee2e6;
        vertical-align: middle;
    }

    /* Column widths - aligned grid */
    #recipeTable thead th:nth-child(1),
    #recipeTable tbody td:nth-child(1) {
        width: 50px;
        text-align: center;
    }

    #recipeTable thead th:nth-child(2),
    #recipeTable tbody td:nth-child(2) {
        width: 90px;
        text-align: center;
    }

    #recipeTable thead th:nth-child(3),
    #recipeTable tbody td:nth-child(3) {
        width: 150px;
    }

    #recipeTable thead th:nth-child(4),
    #recipeTable tbody td:nth-child(4) {
        width: 120px;
    }

    #recipeTable thead th:nth-child(5),
    #recipeTable tbody td:nth-child(5) {
        width: 110px;
        text-align: right;
        padding-right: 20px;
    }

    #recipeTable thead th:nth-child(6),
    #recipeTable tbody td:nth-child(6) {
        width: 180px;
    }

    #recipeTable thead th:nth-child(7),
    #recipeTable tbody td:nth-child(7) {
        width: 100px;
        text-align: center;
    }

    /* Image styling */
    .img-thumb { 
        max-width: 80px; 
        max-height: 60px; 
        display: block; 
        object-fit: cover; 
        border-radius: 4px; 
        margin: auto;
    }
    
    /* Action buttons */
    .action-btn { 
        width: 32px; 
        height: 32px; 
        border-radius: 4px; 
        margin: 0 2px; 
        border: none; 
        cursor: pointer; 
        padding: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    
    /* Description text */
    .desc-preview { 
        display: block;
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        max-width: 180px;
    }

    /* Search and controls section */
    .recipe-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 15px;
        flex-wrap: wrap;
    }

    .recipe-info {
        font-size: 14px;
        color: #666;
        font-weight: 500;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 400px;
    }

    .search-box input {
        width: 100%;
        padding: 8px 12px 8px 36px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
    }

    .search-box input:focus {
        border-color: #007bff;
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,0.1);
    }

    .search-box i {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #999;
        pointer-events: none;
    }

    /* Pagination styling */
    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 20px;
        gap: 5px;
        flex-wrap: wrap;
    }

    .pagination-btn {
        padding: 6px 10px;
        border: 1px solid #ddd;
        background-color: #fff;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s;
    }

    .pagination-btn:hover {
        background-color: #f8f9fa;
        border-color: #007bff;
    }

    .pagination-btn.active {
        background-color: #007bff;
        color: white;
        border-color: #007bff;
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .pagination-info {
        font-size: 13px;
        color: #666;
        margin: 0 10px;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: #999;
    }

    .empty-state i {
        font-size: 48px;
        margin-bottom: 15px;
        opacity: 0.5;
    }

    /* Responsive adjustments */
    @@media (max-width: 1200px) {
        #recipeTable thead th:nth-child(3),
        #recipeTable tbody td:nth-child(3) {
            width: 120px;
        }

        #recipeTable thead th:nth-child(6),
        #recipeTable tbody td:nth-child(6) {
            width: 150px;
        }
    }

    @@media (max-width: 768px) {
        #recipeTable {
            font-size: 13px;
        }

        #recipeTable thead th,
        #recipeTable tbody td {
            padding: 8px;
        }

        #recipeTable thead th:nth-child(3),
        #recipeTable tbody td:nth-child(3) {
            width: 100px;
        }

        #recipeTable thead th:nth-child(6),
        #recipeTable tbody td:nth-child(6) {
            display: none;
        }

        .action-btn {
            width: 28px;
            height: 28px;
        }

        .recipe-controls {
            flex-direction: column;
            align-items: stretch;
        }

        .search-box {
            max-width: 100%;
        }

        .pagination-container {
            justify-content: center;
        }
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Recipe List</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title font-weight-bold">Recipe Management</h3>
            </div>

            <div class="card-body">
                <!-- Search and Info Controls -->
                <div class="recipe-controls">
                    <div class="recipe-info">
                        <span id="recipeCount">Total Recipes: 0</span>
                    </div>
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="Search by name or category (starts with)..." />
                    </div>
                </div>

                <!-- Recipe Table -->
                <div style="overflow-x: auto;">
                    <table class="table table-striped table-bordered" id="recipeTable">
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price (MMK)</th>
                                <th>Description</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>

                <!-- Empty State -->
                <div id="emptyState" class="empty-state" style="display: none;">
                    <i class="fas fa-inbox"></i>
                    <p>No recipes found</p>
                </div>

                <!-- Pagination -->
                <div class="pagination-container" id="paginationContainer">
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    let allRecipes = [];
    let filteredRecipes = [];
    let currentPage = 1;
    const itemsPerPage = 10;

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function makeDescriptionCell(text, maxLen = 60) {
        text = text || '';
        if (text.length <= maxLen) {
            return `<span class="desc-preview" title="${escapeHtml(text)}">${escapeHtml(text)}</span>`;
        }
        const preview = text.substring(0, maxLen).trimEnd();
        return `<span class="desc-preview" title="${escapeHtml(text)}">${escapeHtml(preview)}...</span>`;
    }

    function getImageUrl(imagePath) {
        if (!imagePath) {
            return '<span class="text-muted text-center d-block">-</span>';
        }

        if (imagePath.startsWith('data:')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe" />`;
        }

        if (imagePath.startsWith('http')) {
            return `<img src="${imagePath}" class="img-thumb" alt="Recipe" />`;
        }

        let fullPath = imagePath;
        if (!imagePath.startsWith('/')) {
            fullPath = '/uploads/recipes/' + imagePath;
        } else if (!imagePath.includes('/uploads/recipes/')) {
            fullPath = '/uploads/recipes/' + imagePath.split('/').pop();
        }

        return `<img src="${fullPath}" class="img-thumb" alt="Recipe" onerror="this.src='/img/placeholder.png'" />`;
    }

    function goEdit(id) {
        window.location = '/Entry/Recipe?id=' + id;
    }

    function deleteRecipe(id) {
        if (!confirm('Are you sure you want to delete this recipe?')) return;
        
        $.ajax({
            type: 'POST',
            url: '/api/delete_recipe',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json',
            dataType: 'json',
            headers: {
                'X-CSRF-TOKEN': $('input[name="__RequestVerificationToken"]').val()
            }
        })
        .done(function (res) {
            if (res.message === 'Success') {
                alert('Recipe deleted successfully');
                loadRecipes();
            } else {
                alert('Error: ' + res.message);
            }
        })
        .fail(function () {
            alert('Failed to delete recipe');
        });
    }

    function renderTable(recipes) {
        const tableBody = $('#recipeTable tbody');
        const emptyState = $('#emptyState');

        if (recipes.length === 0) {
            tableBody.empty();
            emptyState.show();
            $('#paginationContainer').empty();
            return;
        }

        emptyState.hide();
        tableBody.empty();

        recipes.forEach(function (recipe, idx) {
            const row = $('<tr>').append(
                $('<td>').text(idx + 1).css('text-align', 'center'),
                $('<td>').html(getImageUrl(recipe.recipe_img)).css('text-align', 'center'),
                $('<td>').text(recipe.recipe_name || '-'),
                $('<td>').text(recipe.category_name || '-'),
                $('<td>').text(parseFloat(recipe.price || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })).css('text-align', 'right'),
                $('<td>').html(makeDescriptionCell(recipe.description || '', 50)),
                $('<td>').html(`
                    <div style="text-align: center; white-space: nowrap;">
                        <button class="action-btn btn btn-warning btn-sm" title="Edit" onclick="goEdit(${recipe.id})">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="action-btn btn btn-danger btn-sm" title="Delete" onclick="deleteRecipe(${recipe.id})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `).css('text-align', 'center')
            );
            tableBody.append(row);
        });
    }

    function renderPagination() {
        const totalPages = Math.ceil(filteredRecipes.length / itemsPerPage);
        const paginationContainer = $('#paginationContainer');
        paginationContainer.empty();

        if (totalPages <= 1) return;

        // Previous button
        const prevBtn = $('<button>')
            .addClass('pagination-btn')
            .html('<i class="fas fa-chevron-left"></i> Prev')
            .prop('disabled', currentPage === 1)
            .click(function () {
                if (currentPage > 1) {
                    currentPage--;
                    displayPage();
                }
            });
        paginationContainer.append(prevBtn);

        // Page numbers
        for (let i = 1; i <= totalPages; i++) {
            const pageBtn = $('<button>')
                .addClass('pagination-btn')
                .addClass(i === currentPage ? 'active' : '')
                .text(i)
                .click(function () {
                    currentPage = i;
                    displayPage();
                });
            paginationContainer.append(pageBtn);
        }

        // Next button
        const nextBtn = $('<button>')
            .addClass('pagination-btn')
            .html('Next <i class="fas fa-chevron-right"></i>')
            .prop('disabled', currentPage === totalPages)
            .click(function () {
                if (currentPage < totalPages) {
                    currentPage++;
                    displayPage();
                }
            });
        paginationContainer.append(nextBtn);

        // Page info
        paginationContainer.append(
            $('<span>')
                .addClass('pagination-info')
                .text(`Page ${currentPage} of ${totalPages}`)
        );
    }

    function displayPage() {
        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        const pageRecipes = filteredRecipes.slice(startIndex, endIndex);
        
        renderTable(pageRecipes);
        renderPagination();
        window.scrollTo(0, 0);
    }

    function filterRecipes(searchTerm) {
        const term = searchTerm.toLowerCase().trim();
        
        if (!term) {
            // Show all recipes if search box is empty
            filteredRecipes = [...allRecipes];
        } else {
            // Filter: show only recipes that START WITH the search term
            filteredRecipes = allRecipes.filter(recipe => 
                (recipe.recipe_name || '').toLowerCase().startsWith(term) ||
                (recipe.category_name || '').toLowerCase().startsWith(term)
            );
        }

        currentPage = 1;
        displayPage();
    }

    function loadRecipes() {
        $.get('/api/get_all_recipes', function (data) {
            allRecipes = data.recipes || [];
            filteredRecipes = [...allRecipes];

            // Update recipe count
            $('#recipeCount').text(`Total Recipes: ${allRecipes.length}`);

            // Display first page
            currentPage = 1;
            displayPage();
        })
        .fail(function () {
            alert('Failed to load recipes');
        });
    }

    $(document).ready(function () {
        loadRecipes();

        // Search functionality with "starts with" filter
        $('#searchInput').on('keyup', function () {
            filterRecipes($(this).val());
        });
    });
</script>
}