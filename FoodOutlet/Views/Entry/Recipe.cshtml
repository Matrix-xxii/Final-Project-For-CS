@{
    ViewData["Title"] = "Recipe";
}

<div class="content-header"><div class="container-fluid"></div></div>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h3 class="card-title font-weight-bold">Recipe Registration</h3></div>
                    <div class="card-body">
                        <div class="form-group row">
                            <label class="col-md-2 col-form-label font-weight-bold">Name</label>
                            <div class="col-md-4"><input id="txtName" class="form-control" /></div>
                            <label class="col-md-1 col-form-label font-weight-bold">Price</label>
                            <div class="col-md-3"><input id="txtPrice" type="number" step="0.01" class="form-control" /></div>
                        </div>
                        <div class="form-group row">
                            <label class="col-md-2 col-form-label font-weight-bold">Qty</label>
                            <div class="col-md-4"><input id="txtQty" type="number" class="form-control" /></div>
                            <label class="col-md-2 col-form-label font-weight-bold">Status</label>
                            <div class="col-md-4"><input id="txtStatus" class="form-control" /></div>
                        </div>
                        <button id="btnSaveRecipe" class="btn btn-success" onclick="saveRecipe()">Save</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h3 class="card-title font-weight-bold">Recipe List</h3></div>
                    <div class="card-body p-0">
                        <table id="recipeTable" class="table table-striped mb-0"><thead><tr><th>No.</th><th>Name</th><th>Price</th><th>Qty</th><th>Status</th><th>Action</th></tr></thead><tbody></tbody></table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
$(function(){loadRecipes();});
function loadRecipes(){
    $.get('/api/get_all_recipes', function(data){
        var rows='';
        (data.recipes||[]).forEach(function(r,i){
            var num=i+1;
            rows += '<tr><td>'+num+'</td><td>'+r.name+'</td><td>'+r.price+'</td><td>'+r.qty+'</td><td>'+r.qty_status+'</td>'+
                    '<td><button class="btn btn-danger btn-sm" onclick="deleteRecipe('+r.id+')">Delete</button></td></tr>';
        });
        $('#recipeTable tbody').html(rows);
    });
}
function saveRecipe(){
    var payload={ name:$('#txtName').val(), price:parseFloat($('#txtPrice').val()), qty:parseInt($('#txtQty').val()), qty_status:$('#txtStatus').val() };
    $.ajax({type:'POST',url:'/api/set_recipe',data:JSON.stringify(payload),contentType:'application/json'}).done(function(res){
        if(res.message=='Success'){ loadRecipes(); $('#txtName,#txtPrice,#txtQty,#txtStatus').val(''); }
        else alert(res.message);
    });
}
function deleteRecipe(id){ if(!confirm('Delete?'))return; $.post('/api/delete_recipe', JSON.stringify({id:id}), function(res){ if(res.message=='Success') loadRecipes(); else alert(res.message); }); }
</script>
