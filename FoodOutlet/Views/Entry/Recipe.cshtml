@model FoodOutlet.Models.Recipe
@{
    bool isEdit = Model != null && Model.id > 0;
    ViewData["Title"] = isEdit ? "Edit Recipe" : "Recipe Registration";
}

<style>
    .section-card { border-radius: 12px; }
    .form-label-custom { font-weight: 600; text-align: right; padding-top: 8px; }
    .price-box input { border-right: 0; }
    .price-box span { background: #f8f9fa; font-weight: 600; }
    .img-preview { max-width:120px; max-height:120px; display:block; margin-top:8px; }
</style>

<div class="content-header">
    <div class="container-fluid"></div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card section-card shadow-sm">
            <div class="card-header">
                <h4 class="card-title font-weight-bold">@(isEdit ? "Edit Recipe" : "Recipe Registration")</h4>
            </div>

            <div class="card-body">
                <form id="recipeForm" enctype="multipart/form-data" onsubmit="return false;">
                    <input type="hidden" id="hdnId" value="@(Model?.id ?? 0)" />

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label text-right form-label-custom">Category</label>
                        <div class="col-md-9">
                            <select id="ddlCategory" class="form-control">
                                <option value="">-- Select Category --</option>
                                
                            </select>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label text-right form-label-custom">Recipe Name</label>
                        <div class="col-md-9">
                            <input id="txtRecipeName"
                                   class="form-control"
                                   value="@(Model?.recipe_name ?? "")"
                                   placeholder="Enter recipe name"
                                   @(isEdit ? "readonly" : "") />
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label text-right form-label-custom">Price</label>
                        <div class="col-md-9">
                            <div class="input-group price-box">
                                <input id="txtPrice"
                                       class="form-control"
                                       value="@(Model?.price.ToString("0.##") ?? "")"
                                       placeholder="Enter price" />
                                <span class="input-group-text">MMK</span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label text-right form-label-custom">Image</label>
                        <div class="col-md-9">
                            <input type="file" id="imgFile" accept="image/*" class="form-control" />
                            <img id="imgPreview" class="img-preview" src="@(Model?.recipe_img ?? "")" alt="Preview" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label text-right form-label-custom">Description</label>
                        <div class="col-md-9">
                            <textarea id="txtDescription" class="form-control" rows="4">@(Model?.description ?? "")</textarea>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-9 offset-md-3 text-right">
                            @if (isEdit)
                            {
                                <button id="btnSave" class="btn btn-success" onclick="saveRecipe()">
                                    <i class="fas fa-check"></i>Update
                                </button>
                                <a class="btn btn-secondary ml-2" asp-controller="Entry" asp-action="RecipeList">Back to List</a>
                            }
                            else
                            {
                                <button id="btnSave" class="btn btn-success" onclick="saveRecipe()">
                                    <i class="fas fa-check"></i>Create
                                </button>
                                <a class="btn btn-secondary ml-2" asp-controller="Entry" asp-action="Recipe">Clear</a>
                            }
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    // local state for uploaded image path (string)
    let uploadedImageUrl = "";

    // Mirror Registration.cshtml logic structure exactly:
    // 1) call loader on ready
    // 2) loader uses $.ajax GET, empties select, appends items via $.each, and sets selection via inline Razor when editing
    // 3) file change handler uploads to /api/upload_recipe_image
    // 4) save builds object, POSTs to /api/set_recipe, checks res.message, alerts, clears and redirects
    $(document).ready(function () {
        loadCategories();
    });

    function loadCategories() {

        $.ajax({
            type: "GET",
            url: "/api/get_all_categories",
            success: function (data) {

                $("#ddlCategory").empty();
                $("#ddlCategory").append('<option value="">-- Select Category --</option>');

                $.each(data.categories, function (i, cat) {

                    $("#ddlCategory").append(
                        '<option value="' + cat.id + '">' +
                            cat.category_name +
                        '</option>'
                    );

                });
                // if editing, pick existing category (inline Razor mirrors Registration pattern)
                @if(Model != null && Model.category_id > 0){
                    <text>$("#ddlCategory").val("@Model.category_id");</text>
                }
            },

            error: function () {
                alert("Cannot load categories");
            }
        });

    }

    // file upload handler (kept simple and consistent with other views)
    $('#imgFile').on('change', function () {
        var file = this.files && this.files[0];
        if (!file) return;

        var form = new FormData();
        form.append('file', file);

        $('#btnSave').prop('disabled', true);
        $.ajax({
            url: '/api/upload_recipe_image',
            type: 'POST',
            data: form,
            contentType: false,
            processData: false
        })
        .done(function (res) {
            if (res && res.imageUrl) {
                uploadedImageUrl = res.imageUrl;
                $('#imgPreview').attr('src', uploadedImageUrl);
            } else {
                alert('Upload failed');
            }
        })
        .fail(function () {
            alert('Image upload failed');
        })
        .always(function () {
            $('#btnSave').prop('disabled', false);
        });
    });

    // saveRecipe mirrors saveStaff's structure and behavior
    function saveRecipe() {

        var obj = {
            id: parseInt($('#hdnId').val()) || 0,
            recipe_name: $('#txtRecipeName').val().trim(),
            category_id: parseInt($('#ddlCategory').val()) || 0,
            recipe_img: uploadedImageUrl || $('#imgPreview').attr('src') || "",
            description: $('#txtDescription').val().trim(),
            price: parseFloat($('#txtPrice').val()) || 0
        };

        console.log(obj);

        if (!obj.recipe_name) { alert('Recipe name required'); return; }
        if (!obj.price || obj.price <= 0) { alert('Invalid price'); return; }

        $.ajax({
            type: "POST",
            url: "/api/set_recipe",
            data: JSON.stringify(obj),
            contentType: "application/json; charset=utf-8",
            dataType: "json"
        }).done(function (res) {

            if (res.message == "Success" || res.message == "Updated") {
                alert("Saved");
                clearForm();
                window.location = '/Entry/RecipeList';
            } else {
                alert(res.message);
            }

        }).fail(function () {
            alert('Save failed');
        });
    }

    // clearForm follows the same semantics as Registration.clearForm
    function clearForm() {
        $('#hdnId').val(0);
        $('#txtRecipeName').val('');
        $('#ddlCategory').val('');
        $('#txtPrice').val('');
        $('#txtDescription').val('');
        // reset preview and uploaded state
        $('#imgPreview').attr('src', '');
        uploadedImageUrl = '';
    }
</script>
}