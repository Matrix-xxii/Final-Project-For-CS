@{
    ViewData["Title"] = "Table Order";
    Layout = "~/Views/Shared/_LayoutWebsite.cshtml";
    int tableNumber = ViewData["TableNumber"] != null ? (int)ViewData["TableNumber"] : 0;
    var latestItemName = ViewData["LatestItemName"] as string ?? "New Items";
    var latestItemImage = ViewData["LatestItemImage"] as string ?? "/img/sticky-rice.jpg";
}

<style>
    .container-fluid {
        padding: 0;
        max-width: 100%;
        width: 100%;
    }

    .food-grid-wrapper {
        padding: 0 1.25rem;
        width: 100%;
    }

    .new-items-banner {
        background: #fff;
        border-radius: 24px;
        width: min(650px, 92%);
        margin-top: 0;
        margin-bottom: 2rem;
        margin-left: auto !important;
        margin-right: auto !important;
        padding: 0.85rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.09);
    }

    .new-items-image img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 16px;
    }

    .new-items-content h2 {
        color: #b51513;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0;
        line-height: 1.1;
    }

    .new-items-content p {
        color: #111;
        font-size: 1.05rem;
        font-weight: 600;
        margin: 0.25rem 0 0;
        line-height: 1.2;
    }

    .food-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2.4rem 1.5rem;
        margin: 1.5rem 0 2rem;
        padding-top: 1.5rem;
        width: 100%;
    }

    .food-card {
        position: relative;
        background: #fff;
        border-radius: 22px;
        padding: 0.7rem 0.9rem 0.85rem;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
        margin-top: 16px;
    }

    .food-card-image {
        position: absolute;
        left: 0.85rem;
        top: -28px;
        width: 92px;
        height: 92px;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.16);
        background: #fff;
    }

    .food-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .food-card-body {
        padding-left: 100px;
        padding-top: 0.1rem;
        min-height: 78px;
    }

    .food-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.1rem;
    }

    .food-card-title {
        color: #111;
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1.15;
        margin: 0;
        word-break: break-word;
    }

    .food-card-price {
        margin-top: 0.05rem;
        color: #333;
        font-size: 0.95rem;
        font-weight: 600;
        padding-left: 100px;
    }

    .food-card-info-btn {
        background: #111;
        border: none;
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.95rem;
        flex-shrink: 0;
    }

    .food-card-meta {
        margin-top: 0.7rem;
    }

    .food-card-meta-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.45rem;
    }

    .food-card-meta-label {
        min-width: 76px;
        color: #111;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1;
    }

    .food-card-category {
        background: #e5e5e5;
        border-radius: 999px;
        color: #111;
        font-size: 1rem;
        font-weight: 700;
        padding: 0.2rem 0.95rem;
        line-height: 1;
    }

    .food-card-stock {
        display: inline-block;
        font-size: 0.78rem;
        border-radius: 999px;
        padding: 0.12rem 0.55rem;
        font-weight: 700;
        margin: 0.05rem 0 0.5rem 76px;
    }

    .food-card-stock.in-stock {
        color: #1f7d3f;
        background: #dff3e6;
    }

    .food-card-stock.out-of-stock {
        color: #b51d1d;
        background: #f8dede;
    }

    .food-card-quantity {
        display: flex;
        align-items: center;
        gap: 0.45rem;
    }

    .qty-btn {
        width: 30px;
        height: 30px;
        border: none;
        border-radius: 9px;
        background: #111;
        color: #fff;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .qty-display {
        min-width: 50px;
        border-radius: 999px;
        background: #e5e5e5;
        text-align: center;
        font-weight: 700;
        font-size: 0.95rem;
        color: #111;
        padding: 0.1rem 0.55rem;
        line-height: 1.2;
    }

    .food-card-actions {
        margin-top: 0.55rem;
        display: flex;
        gap: 0.45rem;
    }

    .food-card-actions button {
        flex: 1;
        border: none;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 0.4rem 0.4rem;
        cursor: pointer;
        line-height: 1.2;
    }

    .btn-add-cart {
        background: #e6e6e6;
        color: #111;
    }

    .btn-order-now {
        background: #ebebeb;
        color: #111;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #888;
        grid-column: 1 / -1;
    }

    .recipe-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.25);
        display: none;
        align-items: flex-start;
        justify-content: center;
        z-index: 1200;
        padding: 2rem 1rem;
    }

    .recipe-modal-overlay.active {
        display: flex;
    }

    .recipe-modal-card {
        width: min(980px, 100%);
        background: #fff;
        border-radius: 28px;
        border: 3px solid #e4d31a;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.16);
        padding: 1.75rem 2rem 2rem;
    }

    .recipe-modal-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .recipe-modal-img {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .recipe-modal-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111;
        margin: 0;
        flex: 1;
    }

    .recipe-modal-close {
        border: none;
        background: #ef3e3e;
        color: #fff;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .recipe-modal-desc {
        color: #111;
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 1.25rem;
        white-space: pre-line;
    }

    .recipe-modal-subtitle {
        font-size: 1.95rem;
        font-weight: 800;
        margin: 0 0 0.6rem;
        color: #111;
    }

    .recipe-modal-ingredients {
        color: #111;
        font-size: 1.05rem;
        line-height: 1.65;
        white-space: pre-line;
    }

    /* Responsive Design */
    @@media (min-width: 1200px) {
        .food-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 2.4rem 1.5rem;
        }
    }

    @@media (min-width: 1600px) {
        .food-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1024px) {
        .food-grid {
            gap: 2rem 1.1rem;
        }

        .food-card-image {
            width: 84px;
            height: 84px;
            top: -24px;
        }

        .food-card-body,
        .food-card-price {
            padding-left: 92px;
        }

        .food-card-title {
            font-size: 1.15rem;
        }

        .food-card-meta-label {
            min-width: 68px;
            font-size: 1rem;
        }

        .food-card-stock {
            margin-left: 68px;
        }
    }

    @@media (max-width: 768px) {
        .food-grid-wrapper {
            padding: 0 0.85rem;
        }

        .food-grid {
            grid-template-columns: 1fr;
            gap: 2.4rem;
        }

        .new-items-banner {
            width: 100%;
            padding: 0.65rem 0.9rem;
            margin-bottom: 1.5rem;
        }

        .new-items-image img {
            width: 60px;
            height: 60px;
        }

        .new-items-content h2 {
            font-size: 1.4rem;
        }

        .new-items-content p {
            font-size: 0.95rem;
        }
    }

    @@media (max-width: 480px) {
        .food-card {
            padding: 0.6rem 0.8rem 0.75rem;
        }

        .food-card-image {
            width: 76px;
            height: 76px;
            top: -22px;
            border-radius: 14px;
        }

        .food-card-body {
            padding-left: 84px;
            min-height: 70px;
        }

        .food-card-price {
            padding-left: 84px;
            font-size: 0.88rem;
        }

        .food-card-title {
            font-size: 1.05rem;
        }

        .food-card-meta-label {
            min-width: 60px;
            font-size: 0.92rem;
        }

        .food-card-category {
            font-size: 0.85rem;
            padding: 0.18rem 0.8rem;
        }

        .food-card-stock {
            margin-left: 60px;
        }

        .food-card-actions button {
            font-size: 0.78rem;
        }

        .qty-btn {
            width: 26px;
            height: 26px;
        }

        .qty-display {
            min-width: 42px;
            font-size: 0.85rem;
        }
    }
</style>

<!-- Food Grid Wrapper -->
<div class="food-grid-wrapper">
    <!-- New Items Banner -->
    <div class="new-items-banner">
        <div class="new-items-image">
            <img src="@latestItemImage" alt="@latestItemName" onerror="this.src='/img/sticky-rice.jpg'">
        </div>
        <div class="new-items-content">
            <h2>New Items</h2>
            <p>@latestItemName</p>
        </div>
    </div>

    <!-- Food Items Grid -->
    <div class="food-grid" id="foodGrid">
        <!-- Dynamic recipes loaded from database -->
        @if (Model != null && Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                <div class="food-card" data-recipe-id="@item.id" data-stock="@item.stock_qty">
                    <div class="food-card-image">
                        <img src="@item.recipe_img" alt="@item.recipe_name" onerror="this.src='/img/placeholder.png'">
                    </div>
                    <div class="food-card-body">
                        <div class="food-card-header">
                            <h3 class="food-card-title">@item.recipe_name</h3>
                            <button class="food-card-info-btn"
                                    title="More info"
                                    data-recipe-name="@item.recipe_name"
                                    data-recipe-img="@item.recipe_img"
                                    data-recipe-desc="@item.description"
                                    data-recipe-ingredients="@item.ingredients">
                                <i class="fas fa-info"></i>
                            </button>
                        </div>
                        <div class="food-card-price">@($"{item.price:0.00} MMK")</div>

                        <div class="food-card-meta">
                            <div class="food-card-meta-row">
                                <span class="food-card-meta-label">Category:</span>
                                <span class="food-card-category">@item.category_name</span>
                            </div>
                            <span class="food-card-stock @(item.stock_qty <= 0 ? "out-of-stock" : "in-stock")">
                                @(item.stock_qty <= 0 ? "Out of stock" : $"Stock: {item.stock_qty}")
                            </span>

                            <div class="food-card-meta-row">
                                <span class="food-card-meta-label">Qty:</span>
                                <div class="food-card-quantity">
                                    <button class="qty-btn qty-decrease" data-item-id="@item.id" @(item.stock_qty <= 0 ? "disabled" : "")>
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <span class="qty-display" data-item-id="@item.id">0</span>
                                    <button class="qty-btn qty-increase" data-item-id="@item.id" data-stock="@item.stock_qty" @(item.stock_qty <= 0 ? "disabled" : "")>
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="food-card-actions">
                            <button class="btn-add-cart" data-item-id="@item.id" data-recipe-name="@item.recipe_name" data-recipe-price="@item.price" data-recipe-img="@item.recipe_img" @(item.stock_qty <= 0 ? "disabled" : "")>Add To Cart</button>
                            <button class="btn-order-now" data-item-id="@item.id" data-recipe-name="@item.recipe_name" @(item.stock_qty <= 0 ? "disabled" : "")>Order Now</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="grid-column: 1 / -1;">
                <i class="fas fa-inbox"></i>
                <p>No recipes available</p>
                <small>Please check back later</small>
            </div>
        }
    </div>
</div>

<div class="recipe-modal-overlay" id="recipeDetailModal">
    <div class="recipe-modal-card">
        <div class="recipe-modal-header">
            <img id="recipeModalImg" class="recipe-modal-img" src="/img/placeholder.png" alt="Recipe">
            <h2 id="recipeModalTitle" class="recipe-modal-title">Recipe</h2>
            <button class="recipe-modal-close" id="recipeModalClose" aria-label="Close">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <p id="recipeModalCategory" style="font-size: 1rem; color: #c0100b; margin-top: -0.5rem; margin-bottom: 1rem; font-weight: 700; background: #fff3cd; padding: 0.3rem 0.8rem; border-radius: 12px; display: inline-block;"></p>
        <p id="recipeModalDesc" class="recipe-modal-desc"></p>
        <h3 class="recipe-modal-subtitle">Ingredients</h3>
        <p id="recipeModalIngredients" class="recipe-modal-ingredients"></p>
    </div>
</div>

@section Scripts {
<script>
    const TABLE_NUMBER = @tableNumber;
    const CART_KEY = `cart_table_${TABLE_NUMBER}`;
    const CART_SELECTION_KEY = `cart_selected_table_${TABLE_NUMBER}`;
    let cart = {};   // always start fresh — qty display always begins at 0
    let selectedCart = JSON.parse(localStorage.getItem(CART_SELECTION_KEY)) || {};

    // Helper functions - must be outside $(document).ready)
    function updateQtyDisplay(itemId) {
        $(`.qty-display[data-item-id="${itemId}"]`).text(cart[itemId] || 0);
    }

    function loadCartFromStorage() {
        Object.keys(cart).forEach(itemId => {
            updateQtyDisplay(itemId);
        });
    }

    function saveCartToStorage() {
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
    }

    function saveSelectedCart() {
        localStorage.setItem(CART_SELECTION_KEY, JSON.stringify(selectedCart));
    }

    function syncSelectedItemQty(itemId) {
        if (!selectedCart[itemId]) return;
        const qty = cart[itemId] || 0;
        if (qty <= 0) {
            delete selectedCart[itemId];
        } else {
            selectedCart[itemId].qty = qty;
        }
        saveSelectedCart();
    }

    $(document).ready(function() {
        // qty always starts at 0 — no restoration from storage

        // Quantity controls - INCREASE
        $(document).on('click', '.qty-increase', function(e) {
            e.preventDefault();
            const itemId = $(this).data('item-id');
            const stock = parseInt($(this).data('stock')) || 0;
            const current = cart[itemId] || 0;
            if (current >= stock) {
                alert(`⚠ Maximum available stock is ${stock}`);
                return;
            }
            const qty = current + 1;
            cart[itemId] = qty;
            updateQtyDisplay(itemId);
            saveCartToStorage();
            syncSelectedItemQty(itemId);
        });

        // Quantity controls - DECREASE
        $(document).on('click', '.qty-decrease', function(e) {
            e.preventDefault();
            const itemId = $(this).data('item-id');
            console.log('Decrease clicked for item:', itemId);
            const qty = Math.max(0, (cart[itemId] || 0) - 1);
            cart[itemId] = qty;
            updateQtyDisplay(itemId);
            saveCartToStorage();
            syncSelectedItemQty(itemId);
        });

        // Add to cart
        $(document).on('click', '.btn-add-cart', function() {
            const itemId = $(this).data('item-id');
            const recipeName = $(this).data('recipe-name');
            const recipePrice = parseFloat($(this).data('recipe-price')) || 0;
            const recipeImg = $(this).data('recipe-img') || '/img/placeholder.png';
            const qty = cart[itemId] || 0;
            if (qty > 0) {
                selectedCart[itemId] = {
                    itemId: parseInt(itemId),
                    recipeName: recipeName,
                    recipePrice: recipePrice,
                    recipeImg: recipeImg,
                    qty: qty
                };
                saveSelectedCart();
                // reset qty display back to 0 after adding to cart
                cart[itemId] = 0;
                updateQtyDisplay(itemId);
                alert(`✓ Added ${qty} x ${recipeName} to cart`);
            } else {
                alert('⚠ Please select quantity first');
            }
        });

        // Order now
        $(document).on('click', '.btn-order-now', function() {
            const itemId = $(this).data('item-id');
            const recipeName = $(this).data('recipe-name');
            const qty = cart[itemId] || 0;
            if (qty > 0) {
                submitOrderNow(parseInt(itemId), recipeName, qty);
            } else {
                alert('⚠ Please select quantity first');
            }
        });

        // Listen for filter events from navbar
        $(document).on('filtersChanged', function(e, filters) {
            console.log('Content received filters:', filters);
            filterRecipes(filters);
        });

        $(document).on('searchSubmitted', function(e, searchTerm) {
            console.log('Content received search:', searchTerm);
            searchRecipes(searchTerm);
        });

        $(document).on('click', '.food-card-info-btn', function() {
            showRecipeInfo(
                $(this).data('recipe-name'),
                $(this).data('recipe-desc'),
                $(this).data('recipe-ingredients'),
                $(this).data('recipe-img'),
                $(this).closest('.food-card').find('.food-card-category').text()
            );
        });

        $('#recipeModalClose').on('click', function() {
            $('#recipeDetailModal').removeClass('active');
        });

        $('#recipeDetailModal').on('click', function(e) {
            if (e.target.id === 'recipeDetailModal') {
                $('#recipeDetailModal').removeClass('active');
            }
        });
    });

    function showRecipeInfo(name, description, ingredients, img, category) {
        $('#recipeModalTitle').text(name || 'Recipe');
        $('#recipeModalCategory').text(category || '');
        $('#recipeModalDesc').text(description || 'No description available.');
        $('#recipeModalIngredients').text(ingredients || 'No ingredient information available.');
        $('#recipeModalImg')
            .attr('src', img || '/img/placeholder.png')
            .on('error', function() { this.src = '/img/placeholder.png'; });
        $('#recipeDetailModal').addClass('active');
    }

    // Filter recipes by category and price
    function filterRecipes(filters) {
        console.log('Filtering by:', filters);

        // If no filters selected, show all
        if (!filters.categories && !filters.priceRanges ||
            (filters.categories.length === 0 && filters.priceRanges.length === 0)) {
            $('.food-card').show();
            return;
        }

        $('.food-card').each(function() {
            const $card = $(this);
            const category = $card.find('.food-card-category').text().trim();
            const priceText = $card.find('.food-card-price').text().replace(/[^\d.]/g, '');
            const price = parseFloat(priceText) || 0;

            let showCard = true;

            // Filter by category
            if (filters.categories && filters.categories.length > 0) {
                const categoryMatch = filters.categories.some(cat => category.toLowerCase() === cat.toLowerCase());
                if (!categoryMatch) {
                    showCard = false;
                }
            }

            // Filter by price range
            if (showCard && filters.priceRanges && filters.priceRanges.length > 0) {
                const priceMatch = filters.priceRanges.some(range => {
                    if (range === '0-10k') return price >= 0 && price <= 10000;
                    if (range === '10k-50k') return price > 10000 && price <= 50000;
                    if (range === '50k-above') return price > 50000;
                    return false;
                });
                if (!priceMatch) {
                    showCard = false;
                }
            }

            if (showCard) {
                $card.show();
            } else {
                $card.hide();
            }
        });
    }

    // Search recipes
    function searchRecipes(searchTerm) {
        const term = searchTerm.toLowerCase().trim();

        if (term === '') {
            $('.food-card').show();
            return;
        }

        $('.food-card').each(function() {
            const $card = $(this);
            const title = $card.find('.food-card-title').text().toLowerCase();
            const category = $card.find('.food-card-category').text().toLowerCase();
            const description = $card.find('.food-card-info-btn').data('recipe-desc')?.toLowerCase() || '';

            if (title.includes(term) || category.includes(term) || description.includes(term)) {
                $card.show();
            } else {
                $card.hide();
            }
        });
    }

    // Submit order
    function submitOrderNow(recipeId, recipeName, qty) {
        if (!confirm(`Order ${qty} x ${recipeName}?`)) {
            return;
        }

        const orderData = {
            table_number: TABLE_NUMBER,
            items: [
                { recipe_id: recipeId, qty: qty }
            ]
        };

        $.ajax({
            type: 'POST',
            url: '/api/create_order',
            data: JSON.stringify(orderData),
            contentType: 'application/json; charset=utf-8',
            dataType: 'json'
        }).done(function(res) {
            if (res.message === 'Success') {
                alert('✓ Order submitted successfully!');
                cart[recipeId] = 0;
                saveCartToStorage();
                $(`.qty-display[data-item-id="${recipeId}"]`).text(0);
            } else {
                alert('Error: ' + res.message);
            }
        }).fail(function(err) {
            alert('Failed to submit order');
            console.error(err);
        });
    }
</script>
}