@{
    ViewData["Title"] = "Table Order";
    Layout = "~/Views/Shared/_LayoutWebsite.cshtml";
    int tableNumber = ViewData["TableNumber"] != null ? (int)ViewData["TableNumber"] : 0;
}

<style>
    /* Content container - respect full width from layout */
    .container-fluid {
        padding-left: 0;
        padding-right: 0;
        max-width: 100%;
        width: 100%;
    }

    /* Add padding to wrapper instead for better control */
    .food-grid-wrapper {
        padding: 0 1.5rem;
        width: 100%;
    }

    /* New Items Banner */
    .new-items-banner {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        gap: 2rem;
        width: 100%;
    }

    .new-items-image {
        flex-shrink: 0;
    }

    .new-items-image img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 12px;
    }

    .new-items-content {
        flex: 1;
    }

    .new-items-content h2 {
        color: #c0100b;
        font-size: 1.8rem;
        margin: 0 0 0.5rem 0;
        font-weight: 700;
    }

    .new-items-content p {
        color: #333;
        font-size: 0.95rem;
        margin: 0;
        font-weight: 500;
    }

    /* Food Grid */
    .food-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
        width: 100%;
    }

    .food-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .food-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }

    .food-card-image {
        width: 100%;
        height: 180px;
        overflow: hidden;
        background: #f5f5f5;
    }

    .food-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .food-card-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .food-card-header {
        display: flex;
        align-items: start;
        justify-content: space-between;
        margin-bottom: 1rem;
        gap: 0.5rem;
    }

    .food-card-title {
        color: #333;
        font-weight: 600;
        font-size: 1rem;
        margin: 0;
        flex: 1;
    }

    .food-card-price {
        color: #999;
        font-size: 0.9rem;
        min-width: max-content;
        font-weight: 600;
    }

    .food-card-info-btn {
        background: #333;
        border: none;
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.8rem;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .food-card-info-btn:hover {
        background: #c0100b;
    }

    .food-card-category {
        background: #e8e8e8;
        color: #666;
        padding: 0.4rem 0.8rem;
        border-radius: 12px;
        font-size: 0.75rem;
        display: inline-block;
        margin-bottom: 0.4rem;
        width: fit-content;
    }

    .food-card-stock {
        display: inline-block;
        font-size: 0.75rem;
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        margin-bottom: 0.75rem;
        font-weight: 600;
    }

    .food-card-stock.in-stock {
        background: #e6f9ee;
        color: #1e7e34;
    }

    .food-card-stock.out-of-stock {
        background: #fde8e8;
        color: #c0100b;
    }

    .food-card-quantity {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .qty-btn {
        background: #333;
        border: none;
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .qty-btn:hover {
        background: #c0100b;
    }

    .qty-display {
        flex: 1;
        text-align: center;
        color: #333;
        font-weight: 500;
        min-width: 30px;
    }

    .food-card-actions {
        display: flex;
        gap: 0.5rem;
    }

    .food-card-actions button {
        flex: 1;
        padding: 0.75rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-add-cart {
        background: #e8e8e8;
        color: #333;
    }

    .btn-add-cart:hover {
        background: #d0d0d0;
    }

    .btn-order-now {
        background: #c0100b;
        color: white;
    }

    .btn-order-now:hover {
        background: #a00a08;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #999;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .empty-state p {
        font-size: 1.1rem;
        margin: 0.5rem 0;
    }

    /* Responsive Design */
    @@media (max-width: 1024px) {
        .food-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        .food-grid-wrapper {
            padding: 0 1rem;
        }

        .new-items-banner {
            padding: 1rem;
            gap: 1.5rem;
        }

        .new-items-image img {
            width: 100px;
            height: 100px;
        }

        .new-items-content h2 {
            font-size: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .food-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .new-items-banner {
            flex-direction: column;
            text-align: center;
            padding: 1rem;
        }

        .new-items-image {
            width: 100%;
        }

        .new-items-image img {
            width: 100%;
            max-width: 150px;
            height: auto;
        }

        .food-grid-wrapper {
            padding: 0 0.75rem;
        }
    }

    @@media (max-width: 480px) {
        .food-grid {
            gap: 0.75rem;
        }

        .food-card-body {
            padding: 1rem;
        }

        .food-card-title {
            font-size: 0.9rem;
        }

        .new-items-content h2 {
            font-size: 1.2rem;
        }

        .new-items-content p {
            font-size: 0.85rem;
        }

        .food-grid-wrapper {
            padding: 0 0.5rem;
        }
    }
</style>

<!-- Food Grid Wrapper -->
<div class="food-grid-wrapper">
    <!-- New Items Banner -->
    <div class="new-items-banner">
        <div class="new-items-image">
            <img src="~/img/sticky-rice.jpg" alt="New Items">
        </div>
        <div class="new-items-content">
            <h2>New Items</h2>
            <p>Sticky rice in Bamboo</p>
        </div>
    </div>

    <!-- Food Items Grid -->
    <div class="food-grid" id="foodGrid">
        <!-- Dynamic recipes loaded from database -->
        @if (Model != null && Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                <div class="food-card" data-recipe-id="@item.id" data-stock="@item.stock_qty">
                    <div class="food-card-image">
                        <img src="@item.recipe_img" alt="@item.recipe_name" onerror="this.src='/img/placeholder.png'">
                    </div>
                    <div class="food-card-body">
                        <div class="food-card-header">
                            <h3 class="food-card-title">@item.recipe_name</h3>
                            <span class="food-card-price">@($"{item.price:0.00} MMK")</span>
                            <button class="food-card-info-btn" title="More info" onclick="showRecipeInfo('@item.id', '@item.recipe_name', '@(item.description?.Replace("'", "\\'") ?? "")')">
                                <i class="fas fa-info"></i>
                            </button>
                        </div>

                        <span class="food-card-category">@item.category_name</span>
                        <span class="food-card-stock @(item.stock_qty <= 0 ? "out-of-stock" : "in-stock")">
                            @(item.stock_qty <= 0 ? "Out of stock" : $"Stock: {item.stock_qty}")
                        </span>

                        <div class="food-card-quantity">
                            <button class="qty-btn qty-decrease" data-item-id="@item.id" @(item.stock_qty <= 0 ? "disabled" : "")>
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="qty-display" data-item-id="@item.id">0</span>
                            <button class="qty-btn qty-increase" data-item-id="@item.id" data-stock="@item.stock_qty" @(item.stock_qty <= 0 ? "disabled" : "")>
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>

                        <div class="food-card-actions">
                            <button class="btn-add-cart" data-item-id="@item.id" data-recipe-name="@item.recipe_name" data-recipe-price="@item.price" data-recipe-img="@item.recipe_img" @(item.stock_qty <= 0 ? "disabled" : "")>Add To Cart</button>
                            <button class="btn-order-now" data-item-id="@item.id" data-recipe-name="@item.recipe_name" @(item.stock_qty <= 0 ? "disabled" : "")>Order Now</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="grid-column: 1 / -1;">
                <i class="fas fa-inbox"></i>
                <p>No recipes available</p>
                <small>Please check back later</small>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    const TABLE_NUMBER = @tableNumber;
    const CART_KEY = `cart_table_${TABLE_NUMBER}`;
    const CART_SELECTION_KEY = `cart_selected_table_${TABLE_NUMBER}`;
    let cart = JSON.parse(localStorage.getItem(CART_KEY)) || {};
    let selectedCart = JSON.parse(localStorage.getItem(CART_SELECTION_KEY)) || {};

    // Helper functions - must be outside $(document).ready)
    function updateQtyDisplay(itemId) {
        $(`.qty-display[data-item-id="${itemId}"]`).text(cart[itemId] || 0);
    }

    function loadCartFromStorage() {
        Object.keys(cart).forEach(itemId => {
            updateQtyDisplay(itemId);
        });
    }

    function saveCartToStorage() {
        localStorage.setItem(CART_KEY, JSON.stringify(cart));
    }

    function saveSelectedCart() {
        localStorage.setItem(CART_SELECTION_KEY, JSON.stringify(selectedCart));
    }

    function syncSelectedItemQty(itemId) {
        if (!selectedCart[itemId]) return;
        const qty = cart[itemId] || 0;
        if (qty <= 0) {
            delete selectedCart[itemId];
        } else {
            selectedCart[itemId].qty = qty;
        }
        saveSelectedCart();
    }

    $(document).ready(function() {
        // Load quantities from localStorage on page load
        loadCartFromStorage();

        // Quantity controls - INCREASE
        $(document).on('click', '.qty-increase', function(e) {
            e.preventDefault();
            const itemId = $(this).data('item-id');
            const stock = parseInt($(this).data('stock')) || 0;
            const current = cart[itemId] || 0;
            if (current >= stock) {
                alert(`⚠ Maximum available stock is ${stock}`);
                return;
            }
            const qty = current + 1;
            cart[itemId] = qty;
            updateQtyDisplay(itemId);
            saveCartToStorage();
            syncSelectedItemQty(itemId);
        });

        // Quantity controls - DECREASE
        $(document).on('click', '.qty-decrease', function(e) {
            e.preventDefault();
            const itemId = $(this).data('item-id');
            console.log('Decrease clicked for item:', itemId);
            const qty = Math.max(0, (cart[itemId] || 0) - 1);
            cart[itemId] = qty;
            updateQtyDisplay(itemId);
            saveCartToStorage();
            syncSelectedItemQty(itemId);
        });

        // Add to cart
        $(document).on('click', '.btn-add-cart', function() {
            const itemId = $(this).data('item-id');
            const recipeName = $(this).data('recipe-name');
            const recipePrice = parseFloat($(this).data('recipe-price')) || 0;
            const recipeImg = $(this).data('recipe-img') || '/img/placeholder.png';
            const qty = cart[itemId] || 0;
            if (qty > 0) {
                selectedCart[itemId] = {
                    itemId: parseInt(itemId),
                    recipeName: recipeName,
                    recipePrice: recipePrice,
                    recipeImg: recipeImg,
                    qty: qty
                };
                saveSelectedCart();
                alert(`✓ Added ${qty} x ${recipeName} to cart`);
            } else {
                alert('⚠ Please select quantity first');
            }
        });

        // Order now
        $(document).on('click', '.btn-order-now', function() {
            const itemId = $(this).data('item-id');
            const recipeName = $(this).data('recipe-name');
            const qty = cart[itemId] || 0;
            if (qty > 0) {
                submitOrderNow(parseInt(itemId), recipeName, qty);
            } else {
                alert('⚠ Please select quantity first');
            }
        });

        // Listen for filter events from navbar
        $(document).on('filtersChanged', function(e, filters) {
            console.log('Content received filters:', filters);
            filterRecipes(filters);
        });

        $(document).on('searchSubmitted', function(e, searchTerm) {
            console.log('Content received search:', searchTerm);
            searchRecipes(searchTerm);
        });
    });

    // Show recipe information modal/alert
    function showRecipeInfo(id, name, description) {
        alert(`${name}\n\nDescription: ${description || 'No description available'}`);
    }

    // Filter recipes by category and price
    function filterRecipes(filters) {
        console.log('Filtering by:', filters);
        
        if (!filters.categories && !filters.priceRanges || 
            (filters.categories.length === 0 && filters.priceRanges.length === 0)) {
            $('.food-card').show();
            return;
        }
    }

    // Search recipes
    function searchRecipes(searchTerm) {
        const term = searchTerm.toLowerCase();
        
        $('.food-card').each(function() {
            const title = $(this).find('.food-card-title').text().toLowerCase();
            const description = $(this).find('.food-card-category').text().toLowerCase();
            
            if (title.includes(term) || description.includes(term)) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    }

    // Submit order
    function submitOrderNow(recipeId, recipeName, qty) {
        if (!confirm(`Order ${qty} x ${recipeName}?`)) {
            return;
        }

        const orderData = {
            table_number: TABLE_NUMBER,
            items: [
                { recipe_id: recipeId, qty: qty }
            ]
        };

        $.ajax({
            type: 'POST',
            url: '/api/create_order',
            data: JSON.stringify(orderData),
            contentType: 'application/json; charset=utf-8',
            dataType: 'json'
        }).done(function(res) {
            if (res.message === 'Success') {
                alert('✓ Order submitted successfully!');
                cart[recipeId] = 0;
                saveCartToStorage();
                $(`.qty-display[data-item-id="${recipeId}"]`).text(0);
            } else {
                alert('Error: ' + res.message);
            }
        }).fail(function(err) {
            alert('Failed to submit order');
            console.error(err);
        });
    }
</script>
}