@model List<dynamic>
@{
    var role      = ViewData["Role"] as string ?? "";
    var pageTitle = role switch {
        "Cashier" => "Cashier — Order Queue",
        "Chef"    => "Chef — Cooking Queue",
        "Waiter"  => "Waiter — Serving Queue",
        "Cleaner" => "Cleaner — Table Queue",
        _         => "Orders"
    };
    ViewData["Title"] = pageTitle;

    // Cashier sees two separate sections
    var pendingOrders  = Model.Where(o => (string)o.status == "Pending").ToList();

    // Served orders are grouped by table (one entry per table)
    var servedByTable = (ViewData["ServedByTable"] as List<dynamic>) ?? new List<dynamic>();

    // Chief / Waiter — individual order cards
    var singleQueue = Model.Where(o => (string)o.status != "Pending" && (string)o.status != "Served").ToList();

    // Cleaner — grouped by table (one card per table)
    var cleaningByTable = (ViewData["CleaningByTable"] as List<dynamic>) ?? new List<dynamic>();

    // Section label/icon for non-cashier roles
    var sectionIcon  = role switch {
        "Chef"    => "fa-fire",
        "Waiter"  => "fa-concierge-bell",
        "Cleaner" => "fa-broom",
        _         => "fa-list"
    };
    var sectionColor = role switch {
        "Chef"    => "text-warning",
        "Waiter"  => "text-success",
        "Cleaner" => "text-secondary",
        _         => "text-primary"
    };
    var sectionLabel = role switch {
        "Chef"    => "Orders Ready to Cook",
        "Waiter"  => "Meals Ready to Serve",
        "Cleaner" => "Tables to Clean",
        _         => "Queue"
    };

    // Action buttons per role: [label, icon, css-class, next-status]
    var roleButtons = role switch {
        "Chef" => new[] {
            new[] { "Approve", "fa-check",        "btn-success", "Ready"     },
            new[] { "Cancel",  "fa-times",         "btn-danger",  "Cancelled" },
        },
        "Waiter" => new[] {
            new[] { "Order Success", "fa-check-double", "btn-success", "Served"    },
            new[] { "Cancel",        "fa-times",         "btn-danger",  "Cancelled" },
        },
        "Cleaner" => new[] {
            new[] { "Done / Finished", "fa-check-circle", "btn-success", "Done"      },
            new[] { "Cancel",          "fa-times",          "btn-danger",  "Cancelled" },
        },
        _ => Array.Empty<string[]>()
    };
}

<style>
    .order-card {
        border-radius: 10px;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .order-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }
    .order-table-badge {
        font-size: 1.3rem;
        font-weight: 800;
        letter-spacing: 0.5px;
    }
    .order-items-text {
        font-size: 0.85rem;
        color: #555;
        line-height: 1.6;
    }
    .order-time {
        font-size: 0.75rem;
        color: #999;
    }
    .status-dot {
        display: inline-block;
        width: 9px; height: 9px;
        border-radius: 50%;
        margin-right: 5px;
    }
    .empty-queue {
        text-align: center;
        padding: 3rem 1rem;
        color: #aaa;
    }
    .empty-queue i { font-size: 3rem; margin-bottom: 1rem; display: block; }
    .btn-action { min-width: 110px; font-weight: 600; }
    .section-divider {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888;
        border-bottom: 2px solid #eee;
        padding-bottom: 6px;
        margin-bottom: 16px;
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0" style="font-size:1.3rem; font-weight:700;">
            @switch (role)
            {
                case "Cashier":
                    <i class="fas fa-cash-register mr-2 text-info"></i>
                    break;
                case "Chief":
                    <i class="fas fa-utensils mr-2 text-warning"></i>
                    break;
                case "Waiter":
                    <i class="fas fa-concierge-bell mr-2 text-success"></i>
                    break;
                case "Cleaner":
                    <i class="fas fa-broom mr-2 text-secondary"></i>
                    break;
            }
            @pageTitle
            <span class="badge badge-secondary ml-2" id="totalBadge">@(role == "Cashier" ? pendingOrders.Count + servedByTable.Count : role == "Cleaner" ? cleaningByTable.Count : Model.Count)</span>
        </h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">

        @if (role == "Cashier")
        {
            <!-- ===== CASHIER: Pending Section ===== -->
            <div class="section-divider">
                <i class="fas fa-hourglass-half mr-1 text-warning"></i>
                New Orders — Pending Approval
                <span class="badge badge-warning ml-1">@pendingOrders.Count</span>
            </div>

            @if (!pendingOrders.Any())
            {
                <div class="empty-queue mb-4">
                    <i class="fas fa-check-circle text-success"></i>
                    <p>No pending orders right now.</p>
                </div>
            }
            else
            {
                <div class="row mb-4">
                    @foreach (var o in pendingOrders)
                    {
                        <div class="col-md-6 col-lg-4 mb-3" id="card-@o.order_id">
                            <div class="card order-card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="order-table-badge text-dark">Table @o.table_label</div>
                                            <div class="order-time mt-1">
                                                <i class="fas fa-clock mr-1"></i>
                                                @(((DateTime)o.created_at).ToString("dd MMM HH:mm"))
                                            </div>
                                        </div>
                                        <span class="badge badge-warning">@o.status</span>
                                    </div>
                                    <div class="order-items-text mb-3">
                                        <i class="fas fa-receipt mr-1 text-muted"></i>
                                        @o.items_summary
                                    </div>
                                    <div class="d-flex flex-wrap" style="gap:6px;">
                                        <button class="btn btn-success btn-sm btn-action"
                                                onclick="doAction(@o.order_id, 'Approved', this)">
                                            <i class="fas fa-check mr-1"></i>Approve
                                        </button>
                                        <button class="btn btn-danger btn-sm btn-action"
                                                onclick="doAction(@o.order_id, 'Cancelled', this)">
                                            <i class="fas fa-times mr-1"></i>Cancel
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- ===== CASHIER: Served Section (awaiting payment + clean) — grouped by table ===== -->
            <div class="section-divider">
                <i class="fas fa-hand-holding-usd mr-1 text-success"></i>
                Served — Awaiting Payment &amp; Cleanup
                <span class="badge badge-success ml-1">@servedByTable.Count</span>
            </div>

            @if (!servedByTable.Any())
            {
                <div class="empty-queue">
                    <i class="fas fa-inbox text-muted"></i>
                    <p>No tables awaiting payment.</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var t in servedByTable)
                    {
                        var safeId  = ((string)t.table_label).Replace(" ", "-");
                        var rawItems = ((string)t.items_raw).Split('|');
                        var total   = (decimal)t.total_cost;
                        <div class="col-md-6 col-lg-4 mb-3" id="table-card-@safeId">
                            <div class="card order-card h-100 border-success" style="border-width:2px;">
                                <div class="card-header d-flex justify-content-between align-items-center py-2"
                                     style="background:#f8fff8; border-bottom:1px solid #c3e6cb;">
                                    <span class="order-table-badge text-dark">
                                        <i class="fas fa-chair mr-1 text-success"></i>Table @t.table_label
                                    </span>
                                    <span class="badge badge-success">Served</span>
                                </div>
                                <div class="card-body pb-2">
                                    <div class="order-time mb-2">
                                        <i class="fas fa-clock mr-1"></i>
                                        First order: @(((DateTime)t.first_ordered_at).ToString("dd MMM HH:mm"))
                                    </div>

                                    <!-- Item list -->
                                    <ul class="list-unstyled order-items-text mb-2" style="padding-left:4px;">
                                        @foreach (var item in rawItems)
                                        {
                                            if (!string.IsNullOrWhiteSpace(item))
                                            {
                                                <li><i class="fas fa-utensils mr-1 text-muted" style="font-size:0.7rem;"></i>@item.Trim()</li>
                                            }
                                        }
                                    </ul>

                                    <!-- Total cost -->
                                    <div class="d-flex justify-content-between align-items-center mt-2 pt-2"
                                         style="border-top:1px dashed #ddd;">
                                        <span style="font-weight:700; font-size:0.9rem; color:#555;">Total</span>
                                        <span style="font-weight:800; font-size:1.05rem; color:#27ae60;">
                                            @total.ToString("N0") MMK
                                        </span>
                                    </div>
                                </div>
                                <div class="card-footer py-2" style="background:#f8fff8;">
                                    <button class="btn btn-secondary btn-sm btn-action w-100"
                                            onclick="doTableAction('@t.order_ids', 'Cleaning', 'table-card-@safeId', this)">
                                        <i class="fas fa-broom mr-1"></i>Send to Clean
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (role == "Cleaner")
        {
            <!-- ===== CLEANER: Grouped by table ===== -->
            <div class="section-divider">
                <i class="fas fa-broom mr-1 text-secondary"></i>
                Tables to Clean
                <span class="badge badge-secondary ml-1">@cleaningByTable.Count</span>
            </div>

            @if (!cleaningByTable.Any())
            {
                <div class="empty-queue">
                    <i class="fas fa-check-circle text-success"></i>
                    <p>Queue is empty — all caught up!</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var t in cleaningByTable)
                    {
                        var safeId   = ((string)t.table_label).Replace(" ", "-");
                        var rawItems = ((string)t.items_raw).Split('|');
                        <div class="col-md-6 col-lg-4 mb-3" id="table-card-@safeId">
                            <div class="card order-card h-100 border-secondary" style="border-width:2px;">
                                <div class="card-header d-flex justify-content-between align-items-center py-2"
                                     style="background:#f9f9f9; border-bottom:1px solid #ddd;">
                                    <span class="order-table-badge text-dark">
                                        <i class="fas fa-chair mr-1 text-secondary"></i>Table @t.table_label
                                    </span>
                                    <span class="badge badge-secondary">Cleaning</span>
                                </div>
                                <div class="card-body pb-2">
                                    <div class="order-time mb-2">
                                        <i class="fas fa-clock mr-1"></i>
                                        First order: @(((DateTime)t.first_ordered_at).ToString("dd MMM HH:mm"))
                                    </div>
                                    <ul class="list-unstyled order-items-text mb-1" style="padding-left:4px;">
                                        @foreach (var item in rawItems)
                                        {
                                            if (!string.IsNullOrWhiteSpace(item))
                                            {
                                                <li><i class="fas fa-utensils mr-1 text-muted" style="font-size:0.7rem;"></i>@item.Trim()</li>
                                            }
                                        }
                                    </ul>
                                </div>
                                <div class="card-footer py-2" style="background:#f9f9f9;">
                                    <div class="d-flex" style="gap:6px;">
                                        <button class="btn btn-success btn-sm btn-action flex-fill"
                                                onclick="doTableAction('@t.order_ids', 'Done', 'table-card-@safeId', this)">
                                            <i class="fas fa-check-circle mr-1"></i>Done
                                        </button>
                                        <button class="btn btn-danger btn-sm btn-action flex-fill"
                                                onclick="doTableAction('@t.order_ids', 'Cancelled', 'table-card-@safeId', this)">
                                            <i class="fas fa-times mr-1"></i>Cancel
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <!-- ===== SINGLE QUEUE (Chief / Waiter) ===== -->
            <div class="section-divider">
                <i class="fas @sectionIcon mr-1 @sectionColor"></i>
                @sectionLabel
                <span class="badge badge-secondary ml-1">@singleQueue.Count</span>
            </div>

            @if (!singleQueue.Any())
            {
                <div class="empty-queue">
                    <i class="fas fa-check-circle text-success"></i>
                    <p>Queue is empty — all caught up!</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var o in singleQueue)
                    {
                        <div class="col-md-6 col-lg-4 mb-3" id="card-@o.order_id">
                            <div class="card order-card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="order-table-badge text-dark">Table @o.table_label</div>
                                            <div class="order-time mt-1">
                                                <i class="fas fa-clock mr-1"></i>
                                                @(((DateTime)o.created_at).ToString("dd MMM HH:mm"))
                                            </div>
                                        </div>
                                        <span class="badge badge-info">@o.status</span>
                                    </div>
                                    <div class="order-items-text mb-3">
                                        <i class="fas fa-receipt mr-1 text-muted"></i>
                                        @o.items_summary
                                    </div>
                                    <div class="d-flex flex-wrap" style="gap:6px;">
                                        @foreach (var btn in roleButtons)
                                        {
                                            <button class="btn @btn[2] btn-sm btn-action"
                                                    onclick="doAction(@o.order_id, '@btn[3]', this)">
                                                <i class="fas @btn[1] mr-1"></i>@btn[0]
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }

    </div>
</section>

@section Scripts {
<script>
    // Single-order action (Pending approvals, non-cashier queues)
    function doAction(orderId, newStatus, btn) {
        var label = btn.textContent.trim();
        if (!confirm('Set order #' + orderId + ' to "' + newStatus + '"?')) return;

        var card = btn.closest('[id^="card-"]');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Wait...';

        $.ajax({
            type: 'POST',
            url: '/api/order/update_status',
            contentType: 'application/json',
            data: JSON.stringify({ order_id: orderId, new_status: newStatus }),
            success: function () {
                fadeRemove(card);
            },
            error: function (xhr) {
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                    ? xhr.responseJSON.message
                    : 'Failed to update. Please try again.';
                alert(msg);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-redo mr-1"></i>' + label;
            }
        });
    }

    // Table-grouped action (Cashier "Send to Clean" — moves all orders for a table at once)
    function doTableAction(orderIds, newStatus, cardId, btn) {
        var label = btn.textContent.trim();
        if (!confirm('Mark all orders for this table as "' + newStatus + '" and send to cleaner?')) return;

        var card = document.getElementById(cardId);
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>Wait...';

        $.ajax({
            type: 'POST',
            url: '/api/order/update_table_status',
            contentType: 'application/json',
            data: JSON.stringify({ order_ids: orderIds, new_status: newStatus }),
            success: function () {
                fadeRemove(card);
            },
            error: function (xhr) {
                var msg = (xhr.responseJSON && xhr.responseJSON.message)
                    ? xhr.responseJSON.message
                    : 'Failed to update. Please try again.';
                alert(msg);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-redo mr-1"></i>' + label;
            }
        });
    }

    function fadeRemove(card) {
        if (!card) return;
        card.style.transition = 'opacity 0.3s';
        card.style.opacity = '0';
        setTimeout(function () {
            card.remove();
            updateBadgeCount();
        }, 300);
    }

    function updateBadgeCount() {
        var remaining = document.querySelectorAll('[id^="card-"], [id^="table-card-"]').length;
        var badge = document.getElementById('totalBadge');
        if (badge) badge.textContent = remaining;
    }

    // Auto-refresh every 30 seconds so new orders appear
    setTimeout(function () { location.reload(); }, 30000);
</script>
}
