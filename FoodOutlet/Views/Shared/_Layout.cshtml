<script>

        $(function () {
        var url = window.location.href.split('?')[0];

        // Highlight direct links
        $('.nav-sidebar a').filter(function () {
            return this.href === url;
        }).addClass('active');

        // Handle treeview menus
        $('.nav-treeview a').filter(function () {
            return this.href === url;
        }).each(function () {
            $(this).addClass('active');
            $(this)
                .parents('.has-treeview')
                .addClass('menu-open')
                .children('a.nav-link')
                .addClass('active');
        });
    });

</script>

