    <!-- SCRIPTS: load from layout so pages only use section Scripts -->
    

    <script>
        // Navigation highlight - run only once on document load
        var navigationHighlighted = false;
        
        $(document).ready(function() {
            if (navigationHighlighted) return;
            navigationHighlighted = true;
            
            var url = window.location.href.split('?')[0];
            $('.nav-sidebar a').filter(function () {
                return this.href === url;
            }).addClass('active');
            $('.nav-treeview a').filter(function () {
                return this.href === url;
            }).each(function () {
                $(this).addClass('active');
                $(this).parents('.has-treeview').addClass('menu-open').children('a.nav-link').addClass('active');
            });
        });
    </script>

